---
import CmsPageRenderer from '../features/pages/public/components/CmsPageRenderer.astro';
import { getExportPageStaticPaths } from '../features/export/routes';

export const prerender = true;

export function getStaticPaths() {
	return getExportPageStaticPaths();
}

const requestedPath = Astro.url.pathname || '/';
---

<CmsPageRenderer path={requestedPath} canonical={Astro.url.href} apiBaseUrl={`${Astro.url.origin}/api`} />
