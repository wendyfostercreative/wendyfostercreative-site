---
import Layout from '../../../layouts/BaseLayout.astro';

import { loadImageByPath } from '../../../features/media/images/public/ssr';
import type { ImageMediaItem } from '../../../features/media/images/core/types';

import { getExportMediaDetailStaticPaths } from '../../../features/export/routes';

export const prerender = true;

export function getStaticPaths() {
	return getExportMediaDetailStaticPaths();
}

const collection = Astro.params.collection ? String(Astro.params.collection) : '';
const category = Astro.params.category ? String(Astro.params.category) : '';
const slug = Astro.params.slug ? String(Astro.params.slug) : '';

let item: ImageMediaItem | null = null;
try {
	if (collection && category && slug) {
		item = await loadImageByPath(Astro, { collection, category, slug });
	}
} catch {
	item = null;
}

const pageTitle = item?.title ? String(item.title) : 'Photo';
const pageDescription = item?.description ? String(item.description) : '';
const detailPreset = item?.detail_display_preset === 'vertical' || item?.detail_display_preset === 'horizontal'
	? item.detail_display_preset
	: 'square';
const shellClass = detailPreset === 'vertical'
	? 'mt-6 grid gap-8 lg:grid-cols-2 lg:items-start'
	: detailPreset === 'horizontal'
		? 'mt-6 grid gap-6'
		: 'mt-6 grid gap-6 md:grid-cols-2';
const imageWrapClass = detailPreset === 'vertical'
	? 'aspect-[3/5] w-full max-w-[50vw] overflow-hidden rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-panel)] max-lg:max-w-none'
	: '';
const imageClass = detailPreset === 'horizontal'
	? 'max-h-[70vh] w-full rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-panel)] object-contain'
	: detailPreset === 'vertical'
		? 'h-full w-full object-contain'
		: 'w-full rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-panel)]';
const detailClass = detailPreset === 'horizontal' ? 'max-w-[var(--site-content-width)]' : '';
---

<Layout title={pageTitle} description={pageDescription} canonical={Astro.url.toString()}>
	<main class="mx-auto max-w-[var(--site-container-width)] p-6 text-[var(--site-color-text)]">
		<a
			href={`/${collection}`}
			class="inline-flex rounded-[var(--site-radius-button)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-button-bg)] px-4 py-2 text-sm font-medium text-[var(--site-color-button-text)] transition-colors hover:bg-[var(--site-color-button-bg-hover)] hover:text-[var(--site-color-button-text-hover)]"
		>
			Back
		</a>

		{item ? (
			<div class={shellClass} data-detail-display-preset={detailPreset}>
				<div class={imageWrapClass}>
					<img
						src={item?.webp || item?.thumb || ''}
						class={imageClass}
						alt={item?.title || item?.file || ''}
					/>
				</div>
				<div class={detailClass}>
					<h1 class="text-3xl font-semibold tracking-tight text-[var(--site-color-text)]">{item?.title || item?.file || ''}</h1>
					{item?.description ? (
						<p class="mt-4 text-sm leading-6 text-[var(--site-color-text-muted)]">{item.description}</p>
					) : null}

					<div class="mt-6 grid gap-2 text-sm text-[var(--site-color-text)]">
						{item?.price ? (
							<div>
								<span class="font-medium">Price:</span>
								<span class="ml-2">{item.price}</span>
							</div>
						) : null}
						{Array.isArray(item?.materials) && item.materials.filter(Boolean).length ? (
							<div>
								<span class="font-medium">Materials:</span>
								<span class="ml-2">{item.materials.filter(Boolean).join(', ')}</span>
							</div>
						) : null}
						{Array.isArray(item?.tags) && item.tags.filter(Boolean).length ? (
							<div>
								<span class="font-medium">Tags:</span>
								<span class="ml-2">{item.tags.filter(Boolean).join(', ')}</span>
							</div>
						) : null}
					</div>
				</div>
			</div>
		) : (
			<p class="mt-4 text-sm text-[var(--site-color-text-muted)]">Not found.</p>
		)}
	</main>
</Layout>
