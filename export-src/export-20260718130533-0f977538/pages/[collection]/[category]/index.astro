---
import Layout from '../../../layouts/BaseLayout.astro';

import { getMedia } from '../../../features/media/public/api';
import { toImageMediaViewItems } from '../../../features/media/images/core/normalize';

import { getExportMediaCategoryStaticPaths } from '../../../features/export/routes';

export const prerender = true;

export function getStaticPaths() {
	return getExportMediaCategoryStaticPaths();
}

const collection = Astro.params.collection ? String(Astro.params.collection) : '';
const category = Astro.params.category ? String(Astro.params.category) : '';
const apiBaseUrl = `${Astro.url.origin}/api`;

function labelize(value: string): string {
	return value.replace(/[-_]+/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
}

function categoryCandidates(value: string): string[] {
	const normalized = String(value || '').trim().toLowerCase();
	const candidates = [normalized];

	if (normalized.endsWith('s')) {
		candidates.push(normalized.replace(/s+$/, ''));
	} else if (normalized) {
		candidates.push(`${normalized}s`);
	}

	return [...new Set(candidates.filter(Boolean))];
}

let items = [];
try {
	if (collection && category) {
		for (const categoryCandidate of categoryCandidates(category)) {
			const media = await getMedia({
				apiBaseUrl,
				media_role: 'media_image',
				collection,
				category: categoryCandidate,
				limit: 100,
				sort: 'sort_order',
			});
			items = toImageMediaViewItems(media);
			if (items.length > 0) break;
		}
	}
} catch {
	items = [];
}

const collectionLabel = labelize(collection);
const categoryLabel = labelize(category);
const pageTitle = [collectionLabel, categoryLabel].filter(Boolean).join(' / ') || 'Gallery';
const backHref = collection ? `/${collection}` : '/';

function thumbnailImageClass(item): string {
	if (item.detail_display_preset === 'vertical') {
		return 'mx-auto h-full max-w-[62%] object-contain transition group-hover:opacity-90';
	}
	if (item.detail_display_preset === 'horizontal') {
		return 'mx-auto max-h-[62%] w-full object-contain transition group-hover:opacity-90';
	}
	return 'h-full w-full object-cover transition group-hover:opacity-90';
}
---

<Layout title={pageTitle} description={pageTitle} canonical={Astro.url.toString()}>
	<section class="mx-auto w-full max-w-[var(--site-container-width)] p-6 text-[var(--site-color-text)]">
		<a
			href={backHref}
			class="inline-flex rounded-[var(--site-radius-button)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-button-bg)] px-4 py-2 text-sm font-medium text-[var(--site-color-button-text)] transition-colors hover:bg-[var(--site-color-button-bg-hover)] hover:text-[var(--site-color-button-text-hover)]"
		>
			Back
		</a>

		<header class="mt-8 max-w-[var(--site-content-width)]">
			<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--site-color-text-muted)]">{collectionLabel}</p>
			<h1 class="mt-2 text-2xl font-semibold tracking-wide text-[var(--site-color-text)]">{categoryLabel}</h1>
		</header>

		{items.length > 0 ? (
			<div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-3">
				{items.map((item) => (
					<a
						href={item.public_href ?? '#'}
						class="group block overflow-hidden rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-panel)] text-[var(--site-color-text)]"
					>
						<div class="flex aspect-square w-full items-center justify-center bg-[var(--site-color-bg)]">
							<img
								src={item.thumb_path ?? item.file_path}
								alt={item.title ?? ''}
								class={thumbnailImageClass(item)}
							/>
						</div>
						{item.title || item.price ? (
							<div class="grid gap-1 p-3">
								{item.title ? <div class="text-sm font-medium">{item.title}</div> : null}
								{item.price ? <div class="text-sm text-[var(--site-color-text-muted)]">{item.price}</div> : null}
							</div>
						) : null}
					</a>
				))}
			</div>
		) : (
			<p class="mt-8 text-sm text-[var(--site-color-text-muted)]">No images found.</p>
		)}
	</section>
</Layout>
