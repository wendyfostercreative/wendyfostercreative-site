---
import Layout from '../layouts/BaseLayout.astro';

import Container from '../components/ui/Container.astro';
import BtnLk from '../components/ui/BtnLk.astro';

import { loadFeaturedImages } from '../features/media/images/public/ssr';
import { mediaPublicHref } from '../features/media/core/mediaPaths';
import type { ImageMediaItem } from '../features/media/images/core/types';
import CmsPageRenderer from '../features/pages/public/components/CmsPageRenderer.astro';
import { getCmsPageByPath } from '../features/pages/public/api';

let featured: ImageMediaItem[] = [];
let hasCmsHome = false;
const apiBaseUrl = `${Astro.url.origin}/api`;

try {
	await getCmsPageByPath('/', { apiBaseUrl });
	hasCmsHome = true;
} catch {
	hasCmsHome = false;
}

try {
	featured = await loadFeaturedImages(Astro, { limit: 12 });
} catch {
	featured = [];
}

function featuredHref(item: ImageMediaItem): string {
	return mediaPublicHref(item, { fallback: '/' });
}
---

{hasCmsHome ? (
	<CmsPageRenderer path="/" canonical={Astro.url.href} apiBaseUrl={apiBaseUrl} />
) : (
	<Layout>
	  <Container class="pb-1">
	    <div class="flex flex-col items-left">
	      <div>
	        <BtnLk href="/jewelry">Joyce Robins Jewelry</BtnLk>
	      </div>

	      <div>
			<div class="flex gap-4 overflow-x-auto pb-6 pt-6">
				{featured.filter((item) => item?.thumb || item?.webp).map((item) => (
					<a
						href={featuredHref(item)}
						class="block shrink-0"
					>
						<img
							src={item?.thumb || item?.webp || ''}
							alt={item?.title || item?.file || 'Featured item'}
							loading="lazy"
							class="h-64 w-64 rounded-[var(--site-radius-card)] border bg-gray-100 object-cover"
						/>
					</a>
				))}
			</div>
	      </div>
	    </div>
	  </Container>
	  <Container class="pt-0">
	    <div class="flex flex-col items-left gap-6">
	      <div>
	        <BtnLk href="/jewelry">Mary Silverwood Pastels</BtnLk>
	      </div>

	      <div>
	        <div class="flex gap-4 overflow-x-auto pb-2">
	          {featured.filter((item) => item?.thumb || item?.webp).map((item) => (
	            <a
	              href={featuredHref(item)}
	              class="block shrink-0"
	            >
	              <img
	                src={item?.thumb || item?.webp || ''}
	                alt={item?.title || item?.file || 'Featured item'}
	                loading="lazy"
	                class="h-64 w-64 rounded-[var(--site-radius-card)] border bg-gray-100 object-cover"
	              />
	            </a>
	          ))}
	        </div>
	      </div>
	    </div>
	  </Container>
	</Layout>
)}
