---
interface Props {
	id?: string;
	name?: string;
	type?: astroHTML.JSX.HTMLInputTypeAttribute;
	value?: string | number | null;
	placeholder?: string;
	required?: boolean;
	disabled?: boolean;
	readonly?: boolean;
	class?: string;
}

const {
	id,
	name = id,
	type = 'text',
	value = '',
	placeholder,
	required = false,
	disabled = false,
	readonly = false,
	class: className = '',
	...rest
} = Astro.props;

const classes = ['ui-input', className].filter(Boolean).join(' ');
---

<input
	class={classes}
	type={type}
	id={id}
	name={name}
	value={value ?? ''}
	placeholder={placeholder}
	required={required}
	disabled={disabled}
	readonly={readonly}
	{...rest}
/>

<style>
	.ui-input {
		background: var(--site-input-bg);
		border: 1px solid var(--site-input-border);
		border-radius: var(--site-input-radius, var(--site-radius-input));
		box-sizing: border-box;
		color: var(--site-input-text);
		display: block;
		font: inherit;
		font-size: 0.9375rem;
		line-height: var(--site-line-height-body, 1.5);
		padding: var(--site-input-padding-y, 0.375rem) var(--site-input-padding-x, 0.625rem);
		width: 100%;
	}

	.ui-input::placeholder {
		color: var(--site-input-placeholder);
	}

	.ui-input:focus {
		border-color: var(--site-input-focus-ring);
		outline: 2px solid color-mix(in srgb, var(--site-input-focus-ring) 30%, transparent);
		outline-offset: 1px;
	}

	.ui-input:disabled,
	.ui-input:read-only {
		cursor: not-allowed;
		opacity: 0.65;
	}
</style>
