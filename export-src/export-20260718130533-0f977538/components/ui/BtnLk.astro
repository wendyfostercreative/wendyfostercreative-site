---
const { href, class: className, as, ...rest } = Astro.props;
const classes = ['ui-btn-link', className].filter(Boolean).join(' ');
---

{as === 'button' ? (
	<button type="button" class={classes} {...rest}>
		<slot />
	</button>
) : (
	<a href={href} class={classes} {...rest}>
		<slot />
	</a>
)}

<style>
	.ui-btn-link {
		appearance: none;
		background: transparent;
		border: 0;
		color: var(--site-color-text);
		cursor: pointer;
		display: inline-block;
		font: inherit;
		font-size: 1.25rem;
		font-weight: var(--site-font-weight-semibold, 600);
		line-height: 1.2;
		padding: 0;
		text-decoration: none;
		text-transform: uppercase;
	}

	.ui-btn-link:hover {
		color: var(--site-color-text-muted);
		text-decoration: var(--site-button-hover-decoration, underline);
	}

	.ui-btn-link:focus-visible {
		outline: 2px solid var(--site-button-focus-ring, currentColor);
		outline-offset: 2px;
	}
</style>
