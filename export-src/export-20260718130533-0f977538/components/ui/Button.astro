---
type ButtonVariant = 'solid' | 'outline' | 'ghost' | 'text';
type ButtonTone = 'accent' | 'neutral' | 'danger';
type ButtonType = 'button' | 'submit' | 'reset';

interface Props {
	href?: string;
	variant?: ButtonVariant;
	tone?: ButtonTone;
	type?: ButtonType;
	disabled?: boolean;
	class?: string;
	'aria-label'?: string;
	formaction?: string;
	formmethod?: string;
	'data-add-page-section'?: boolean | string;
	'data-export-action'?: string;
	'data-section-move'?: string;
	'data-section-delete'?: boolean | string;
}

const {
	href,
	variant = 'solid',
	tone = 'accent',
	type = 'button',
	disabled = false,
	class: className = '',
	...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const classes = ['ui-button', className].filter(Boolean).join(' ');
---

<Tag
	class={classes}
	href={disabled ? undefined : href}
	type={href ? undefined : type}
	disabled={href ? undefined : disabled}
	aria-disabled={href && disabled ? 'true' : undefined}
	data-variant={variant}
	data-tone={tone}
	{...rest}
>
	<slot />
</Tag>

<style>
	.ui-button {
		align-items: center;
		appearance: none;
		border: 1px solid transparent;
		border-radius: var(--site-button-radius, var(--site-radius-button));
		box-sizing: border-box;
		cursor: pointer;
		display: inline-flex;
		font: inherit;
		font-size: 0.9375rem;
		font-weight: var(--site-font-weight-medium, 500);
		gap: var(--site-space-inline-gap, 0.75rem);
		justify-content: center;
		line-height: 1.2;
		padding: var(--site-button-padding-y, 0.5rem) var(--site-button-padding-x, 0.85rem);
		text-align: center;
		text-decoration: none;
		transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease, opacity 160ms ease;
	}

	.ui-button[data-variant='solid'] {
		background: var(--site-color-button-bg);
		border-color: var(--site-button-border-color, var(--site-color-button-bg));
		color: var(--site-color-button-text);
	}

	.ui-button[data-variant='outline'] {
		background: transparent;
		border-color: var(--site-color-border);
		color: var(--site-color-text);
	}

	.ui-button[data-variant='ghost'],
	.ui-button[data-variant='text'] {
		background: transparent;
		border-color: transparent;
		color: var(--site-color-text);
	}

	.ui-button[data-tone='neutral'][data-variant='solid'] {
		background: var(--site-color-text);
		border-color: var(--site-color-text);
		color: var(--site-color-bg);
	}

	.ui-button[data-tone='danger'][data-variant='solid'] {
		background: var(--site-color-danger);
		border-color: var(--site-color-danger);
		color: var(--site-color-button-text);
	}

	.ui-button[data-tone='danger'][data-variant='outline'] {
		border-color: color-mix(in srgb, var(--site-color-danger) 45%, transparent);
		color: var(--site-color-danger);
	}

	.ui-button[data-tone='danger'][data-variant='ghost'],
	.ui-button[data-tone='danger'][data-variant='text'] {
		color: var(--site-color-danger);
	}

	.ui-button[data-variant='text'] {
		padding-inline: 0;
	}

	.ui-button:hover:not(:disabled):not([aria-disabled='true']) {
		text-decoration: var(--site-button-hover-decoration, none);
	}

	.ui-button[data-variant='solid']:hover:not(:disabled):not([aria-disabled='true']) {
		background: var(--site-color-button-bg-hover);
		color: var(--site-color-button-text-hover);
	}

	.ui-button[data-variant='outline']:hover:not(:disabled):not([aria-disabled='true']),
	.ui-button[data-variant='ghost']:hover:not(:disabled):not([aria-disabled='true']),
	.ui-button[data-variant='text']:hover:not(:disabled):not([aria-disabled='true']) {
		color: var(--site-color-text-muted);
	}

	.ui-button[data-tone='danger'][data-variant='outline']:hover:not(:disabled):not([aria-disabled='true']),
	.ui-button[data-tone='danger'][data-variant='ghost']:hover:not(:disabled):not([aria-disabled='true']),
	.ui-button[data-tone='danger'][data-variant='text']:hover:not(:disabled):not([aria-disabled='true']) {
		color: var(--site-color-danger);
		text-decoration: underline;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	.ui-button:focus-visible {
		outline: 2px solid var(--site-button-focus-ring, currentColor);
		outline-offset: 2px;
	}

	.ui-button[data-tone='danger']:focus-visible {
		outline-color: var(--site-color-danger);
	}

	.ui-button:disabled,
	.ui-button[aria-disabled='true'] {
		cursor: not-allowed;
		opacity: 0.55;
	}
</style>
