---
interface Props {
	id?: string;
	name?: string;
	required?: boolean;
	disabled?: boolean;
	class?: string;
	style?: string;
}

const {
	id,
	name = id,
	required = false,
	disabled = false,
	class: className = '',
	style,
	...rest
} = Astro.props;

const classes = ['ui-select', className].filter(Boolean).join(' ');
---

<select
	class={classes}
	style={style}
	id={id}
	name={name}
	required={required}
	disabled={disabled}
	{...rest}
>
	<slot />
</select>

<style>
	.ui-select {
		appearance: none;
		background-color: var(--site-input-bg);
		background-image: linear-gradient(45deg, transparent 50%, currentColor 50%), linear-gradient(135deg, currentColor 50%, transparent 50%);
		background-position: calc(100% - 0.875rem) 50%, calc(100% - 0.575rem) 50%;
		background-repeat: no-repeat;
		background-size: 0.3rem 0.3rem, 0.3rem 0.3rem;
		border: 1px solid var(--site-input-border);
		border-radius: var(--site-input-radius, var(--site-radius-input));
		box-sizing: border-box;
		color: var(--site-input-text);
		display: block;
		font: inherit;
		font-size: 0.9375rem;
		line-height: var(--site-line-height-body, 1.5);
		padding: var(--site-input-padding-y, 0.375rem) calc(var(--site-input-padding-x, 0.625rem) + 1.125rem) var(--site-input-padding-y, 0.375rem) var(--site-input-padding-x, 0.625rem);
		width: 100%;
	}

	.ui-select:focus {
		border-color: var(--site-input-focus-ring);
		outline: 2px solid color-mix(in srgb, var(--site-input-focus-ring) 30%, transparent);
		outline-offset: 1px;
	}

	.ui-select:disabled {
		cursor: not-allowed;
		opacity: 0.65;
	}
</style>
