---
interface Props {
	id?: string;
	name?: string;
	rows?: number;
	value?: string | null;
	placeholder?: string;
	required?: boolean;
	disabled?: boolean;
	readonly?: boolean;
	class?: string;
}

const {
	id,
	name = id,
	rows = 4,
	value = '',
	placeholder,
	required = false,
	disabled = false,
	readonly = false,
	class: className = '',
	...rest
} = Astro.props;

const classes = ['ui-textarea', className].filter(Boolean).join(' ');
---

<textarea
	class={classes}
	id={id}
	name={name}
	rows={rows}
	placeholder={placeholder}
	required={required}
	disabled={disabled}
	readonly={readonly}
	{...rest}
>{value ?? ''}</textarea>

<style>
	.ui-textarea {
		background: var(--site-input-bg);
		border: 1px solid var(--site-input-border);
		border-radius: var(--site-input-radius, var(--site-radius-input));
		box-sizing: border-box;
		color: var(--site-input-text);
		display: block;
		font: inherit;
		font-size: 0.9375rem;
		line-height: var(--site-line-height-body, 1.5);
		min-height: 2.5rem;
		padding: var(--site-input-padding-y, 0.375rem) var(--site-input-padding-x, 0.625rem);
		resize: vertical;
		width: 100%;
	}

	.ui-textarea::placeholder {
		color: var(--site-input-placeholder);
	}

	.ui-textarea:focus {
		border-color: var(--site-input-focus-ring);
		outline: 2px solid color-mix(in srgb, var(--site-input-focus-ring) 30%, transparent);
		outline-offset: 1px;
	}

	.ui-textarea:disabled,
	.ui-textarea:read-only {
		cursor: not-allowed;
		opacity: 0.65;
	}
</style>
