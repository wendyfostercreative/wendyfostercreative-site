---
import ActionRow from './ActionRow.astro';

interface Props {
	buttonText?: string;
	statusId?: string;
	buttonType?: 'submit' | 'button' | 'reset';
	class?: string;
}

const { buttonText, statusId, buttonType, class: className = '', ...rest } = Astro.props;
---

<ActionRow
	buttonText={buttonText}
	statusId={statusId}
	buttonType={buttonType}
	class={className}
	{...rest}
/>
