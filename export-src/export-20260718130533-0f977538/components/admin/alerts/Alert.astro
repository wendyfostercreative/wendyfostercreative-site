---
import Surface from '../../ui/Surface.astro';

type Variant = 'error' | 'success' | 'warning';

interface Props {
	variant?: Variant;
	class?: string;
}

const { variant = 'error', class: className = '' } = Astro.props;

const variantVars = {
	error: '--ui-surface-bg: var(--admin-color-error-bg); --ui-surface-color: var(--admin-color-error-text); --ui-surface-border: var(--admin-color-error-border);',
	success: '--ui-surface-bg: var(--admin-color-success-bg); --ui-surface-color: var(--admin-color-success-text); --ui-surface-border: var(--admin-color-success-border);',
	warning: '--ui-surface-bg: var(--admin-color-warning-bg); --ui-surface-color: var(--admin-color-warning-text); --ui-surface-border: var(--admin-color-warning-border);',
}[variant];
---

<Surface
	class={['text-sm', className].filter(Boolean).join(' ')}
	style={variantVars}
	tone="surface"
	padding="md"
	radius="card"
	bordered
	role={variant === 'error' ? 'alert' : 'status'}
>
	<slot />
</Surface>
