---
import Surface from '../../ui/Surface.astro';

type SummaryItem = {
	key?: string;
	label: string;
	value: string;
};

interface Props {
	items: SummaryItem[];
	class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<Surface class={['grid gap-3 text-sm sm:grid-cols-2', className].filter(Boolean).join(' ')} tone="surface" padding="md" radius="card" bordered>
	{items.map((item) => (
		<div class="grid gap-1">
			<div class="text-xs font-medium text-[var(--site-color-text-muted)]">{item.label}</div>
			<div class="font-medium text-[var(--site-color-text)]" data-site-config-summary-value={item.key ?? undefined}>{item.value}</div>
		</div>
	))}
</Surface>
