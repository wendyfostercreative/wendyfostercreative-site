---
import Surface from '../../ui/Surface.astro';

interface Props {
	class?: string;
	as?: string;
}

const { class: className = '', as = 'div', ...rest } = Astro.props;
const classes = ['w-full', className].filter(Boolean).join(' ');
---

<Surface as={as} class={classes} tone="surface" padding="md" radius="card" bordered {...rest}>
	<slot />
</Surface>
