---
import Surface from '../../ui/Surface.astro';

interface Props {
	class?: string;
	sticky?: boolean;
}

const { class: className = '', sticky = true, ...rest } = Astro.props;
---

<Surface
	class={['admin-toolbar', sticky && 'admin-toolbar-sticky', className].filter(Boolean).join(' ')}
	tone="surface"
	padding="sm"
	radius="card"
	bordered
	{...rest}
>
	<slot />
</Surface>

<style>
	.admin-toolbar-sticky {
		position: sticky;
		top: 12px;
		z-index: 10;
	}
</style>
