---
interface Props {
	title?: string;
	description?: string;
	class?: string;
}

const { title, description, class: className = '' } = Astro.props;
---

<section class:list={['grid gap-4', className]}>
	{(title || description) && (
		<div>
			{title && <h2 class="text-sm font-semibold text-[var(--site-color-text)]">{title}</h2>}
			{description && <p class="mt-1 text-sm text-[var(--site-color-text-muted)]">{description}</p>}
		</div>
	)}

	<div class="grid gap-4">
		<slot />
	</div>
</section>