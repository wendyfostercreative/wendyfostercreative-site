---
interface Props {
	label?: string;
	forId?: string;
	help?: string;
	class?: string;
}

const {
	label,
	forId,
	help,
	class: className = '',
} = Astro.props;
---

<div class:list={['grid gap-1', className]}>
	{label && (
		<label class="block text-sm font-medium text-[var(--site-color-text)]" for={forId}>
			{label}
		</label>
	)}

	<slot />

	{help && (
		<p class="text-xs text-[var(--site-color-text-muted)]">
			{help}
		</p>
	)}
</div>
