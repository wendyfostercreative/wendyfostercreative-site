---
import UiInput from '../../ui/Input.astro';

interface Props {
	id: string;
	name?: string;
	type?: astroHTML.JSX.HTMLInputTypeAttribute;
	value?: string | number | null;
	placeholder?: string;
	pattern?: string;
	required?: boolean;
	disabled?: boolean;
	readonly?: boolean;
	class?: string;
	'data-template'?: string;
}

const {
	id,
	name = id,
	type = 'text',
	value = '',
	placeholder,
	required = false,
	disabled = false,
	readonly = false,
	class: className = '',
	...rest
} = Astro.props;
---

<UiInput
	class={className}
	type={type}
	id={id}
	name={name}
	value={value}
	placeholder={placeholder}
	required={required}
	disabled={disabled}
	readonly={readonly}
	{...rest}
/>
