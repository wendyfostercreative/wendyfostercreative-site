---
import UiTextarea from '../../ui/Textarea.astro';

interface Props {
	id: string;
	name?: string;
	rows?: number;
	value?: string | null;
	placeholder?: string;
	required?: boolean;
	disabled?: boolean;
	readonly?: boolean;
	class?: string;
}

const {
	id,
	name = id,
	rows = 4,
	value = '',
	placeholder,
	required = false,
	disabled = false,
	readonly = false,
	class: className = '',
	...rest
} = Astro.props;
---

<UiTextarea
	class={className}
	id={id}
	name={name}
	rows={rows}
	value={value}
	placeholder={placeholder}
	required={required}
	disabled={disabled}
	readonly={readonly}
	{...rest}
/>
