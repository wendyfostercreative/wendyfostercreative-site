---
interface Props {
	id: string;
	name?: string;
	label: string;
	help?: string;
	checked?: boolean;
	value?: string;
	hiddenFalse?: boolean;
	class?: string;
}

const {
	id,
	name = id,
	label,
	help,
	checked = false,
	value = 'true',
	hiddenFalse = true,
	class: className = '',
	...rest
} = Astro.props;
---

<div class:list={['admin-toggle-row', className]} {...rest}>
	<div class="min-w-0">
		<label class="admin-toggle-row__label" for={id}>
			{hiddenFalse && <input type="hidden" name={name} value="false" />}
			<input
				id={id}
				class="admin-toggle-row__input"
				type="checkbox"
				name={name}
				value={value}
				checked={checked}
			/>
			<span>{label}</span>
		</label>
		{help && <p class="admin-toggle-row__help">{help}</p>}
	</div>
</div>

<style>
	.admin-toggle-row {
		align-items: center;
		background: var(--admin-color-field-bg);
		border: 1px solid var(--admin-color-field-border);
		border-radius: var(--site-radius-input);
		box-sizing: border-box;
		color: var(--admin-color-field-text);
		display: flex;
		justify-content: space-between;
		min-height: 2.5rem;
		padding: 0.625rem 0.75rem;
	}

	.admin-toggle-row__label {
		align-items: center;
		cursor: pointer;
		display: inline-flex;
		gap: 0.625rem;
		min-width: 0;
		font-size: 0.875rem;
		font-weight: var(--site-font-weight-medium, 500);
		line-height: 1.4;
	}

	.admin-toggle-row__input {
		accent-color: var(--site-color-button-bg);
		background: var(--admin-color-field-bg);
		border-color: var(--admin-color-field-border);
		color: var(--admin-color-field-text);
		flex: 0 0 auto;
		height: 1rem;
		width: 1rem;
	}

	.admin-toggle-row__input:focus-visible {
		outline: 2px solid var(--site-button-focus-ring, currentColor);
		outline-offset: 2px;
	}

	.admin-toggle-row__help {
		color: var(--site-color-text-muted);
		font-size: 0.75rem;
		line-height: 1.4;
		margin: 0.25rem 0 0 1.625rem;
	}
</style>
