---
import AdminField from './Field.astro';
import AdminInput from './Input.astro';
import { colorInputValue, normalizeHexColor } from '../../../lib/cssColor';

interface Props {
	label: string;
	id: string;
	name: string;
	value?: string | null;
	help?: string;
}

const { label, id, name, value = '', help } = Astro.props;
const textValue = normalizeHexColor(value) ?? String(value || '');
const pickerValue = colorInputValue(value);
---

<AdminField label={label} forId={id} help={help}>
	<div class="flex items-center gap-2" data-admin-color-field>
		<input
			class="h-9 w-11 shrink-0 cursor-pointer rounded-[var(--site-radius-input)] border border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] p-1"
			type="color"
			value={pickerValue}
			aria-label={`${label} color picker`}
			data-admin-color-picker
		/>
		<AdminInput
			class="font-mono"
			type="text"
			id={id}
			name={name}
			value={textValue}
			placeholder="#000000"
			pattern="^#[0-9a-fA-F]{6}$"
			data-admin-color-text
		/>
	</div>
</AdminField>

<script>
	document.querySelectorAll<HTMLElement>('[data-admin-color-field]').forEach((field) => {
		const picker = field.querySelector<HTMLInputElement>('[data-admin-color-picker]');
		const text = field.querySelector<HTMLInputElement>('[data-admin-color-text]');
		if (!picker || !text) return;

		picker.addEventListener('input', () => {
			text.value = picker.value.toLowerCase();
		});

		text.addEventListener('change', () => {
			const value = text.value.trim().toLowerCase();
			if (/^#[0-9a-f]{6}$/.test(value)) picker.value = value;
		});
	});
</script>
