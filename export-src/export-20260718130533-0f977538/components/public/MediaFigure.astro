---
type MediaShape = 'square' | 'wide' | 'natural';
type MediaWidth = 'hero' | 'default' | 'full';

interface Props {
	src?: string | null;
	alt?: string | null;
	href?: string | null;
	labelFallback?: string | null;
	shape?: MediaShape;
	width?: MediaWidth;
	class?: string;
	loading?: 'eager' | 'lazy';
}

const {
	src,
	alt,
	href,
	labelFallback,
	shape = 'square',
	width = 'default',
	class: className = '',
	loading = 'lazy',
	...rest
} = Astro.props;

const imageSrc = typeof src === 'string' ? src.trim() : '';
const imageHref = typeof href === 'string' ? href.trim() : '';
const imageAlt = typeof alt === 'string' ? alt : '';
const accessibleLabel = imageAlt || labelFallback || 'View image link';
const classes = ['public-media-figure', className].filter(Boolean).join(' ');
---

{imageSrc ? (
	<figure class={classes} data-shape={shape} data-width={width} {...rest}>
		{imageHref ? (
			<a href={imageHref} class="public-media-figure__link" aria-label={accessibleLabel}>
				<img src={imageSrc} alt={imageAlt} loading={loading} class="public-media-figure__image" />
			</a>
		) : (
			<img src={imageSrc} alt={imageAlt} loading={loading} class="public-media-figure__image" />
		)}
	</figure>
) : null}

<style>
	.public-media-figure {
		margin: 0 auto;
		width: 100%;
	}

	.public-media-figure[data-width='hero'] {
		max-width: 28rem;
	}

	.public-media-figure[data-width='default'] {
		max-width: 30rem;
	}

	.public-media-figure[data-width='full'] {
		max-width: none;
	}

	.public-media-figure__link {
		display: block;
	}

	.public-media-figure__image {
		display: block;
		width: 100%;
	}

	.public-media-figure[data-shape='square'] .public-media-figure__image {
		aspect-ratio: 1 / 1;
		object-fit: cover;
	}

	.public-media-figure[data-shape='wide'] .public-media-figure__image {
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.public-media-figure[data-shape='natural'] .public-media-figure__image {
		height: auto;
	}
</style>
