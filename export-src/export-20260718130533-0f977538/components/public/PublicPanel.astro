---
import Surface from '../ui/Surface.astro';

type PanelTone = 'surface' | 'soft' | 'plain';
type PanelPadding = 'sm' | 'md' | 'lg';

interface Props {
	as?: string;
	tone?: PanelTone;
	padding?: PanelPadding;
	class?: string;
}

const {
	as = 'div',
	tone = 'surface',
	padding = 'lg',
	class: className = '',
	...rest
} = Astro.props;
---

<Surface as={as} tone={tone} padding={padding} radius="card" bordered={true} class={className} {...rest}>
	<slot />
</Surface>
