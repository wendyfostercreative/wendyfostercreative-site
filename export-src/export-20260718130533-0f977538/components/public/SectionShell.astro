---
type SectionSpacing = 'hero' | 'default' | 'compact' | 'none';
type SectionSurface = 'transparent' | 'soft' | 'panel';

interface Props {
	as?: string;
	spacing?: SectionSpacing;
	surface?: SectionSurface;
	class?: string;
}

const {
	as = 'section',
	spacing = 'default',
	surface = 'transparent',
	class: className = '',
	...rest
} = Astro.props;

const Tag = as;
const classes = ['public-section-shell', className].filter(Boolean).join(' ');
---

<Tag class={classes} data-spacing={spacing} data-surface={surface} {...rest}>
	<slot />
</Tag>

<style>
	.public-section-shell {
		box-sizing: border-box;
		width: 100%;
	}

	.public-section-shell[data-spacing='hero'] {
		padding-block: 5rem;
	}

	.public-section-shell[data-spacing='default'] {
		padding-block: 4rem;
	}

	.public-section-shell[data-spacing='compact'] {
		padding-block: 3.5rem;
	}

	.public-section-shell[data-spacing='none'] {
		padding-block: 0;
	}

	.public-section-shell[data-surface='soft'] {
		background: var(--site-color-surface-soft, var(--site-color-bg-soft));
	}

	.public-section-shell[data-surface='panel'] {
		background: var(--site-color-panel);
	}

	@media (min-width: 768px) {
		.public-section-shell[data-spacing='hero'] {
			padding-block: 7rem;
		}

		.public-section-shell[data-spacing='default'] {
			padding-block: 6rem;
		}

		.public-section-shell[data-spacing='compact'] {
			padding-block: 5rem;
		}
	}
</style>
