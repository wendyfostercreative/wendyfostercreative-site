---
import '../styles/global.css';
import HeaderNav from '../features/headerNav/public/components/HeaderNav.astro';
import CmsFooter from '../features/footer/public/components/CmsFooter.astro';
import OrionAssistant from '../features/orion/admin/components/OrionAssistant.astro';
import { loadAdminLayoutConfig } from './admin/ssr';
import { loadSiteConfig as loadPublicLayoutConfig } from './public/ssr';
import { loadAdminContext } from '../lib/admin/context';
import { DEFAULT_SITE_THEME, resolveSiteTheme, siteThemeStyleVars } from '../features/siteConfig/core/theme';
import type { SiteConfig } from '../features/siteConfig/core/types';
import type { NavItem } from '../features/headerNav/core/types';
import type { HeaderNavSettings } from '../features/headerNav/core/types';
import type { FooterSettings } from '../features/footer/core/types';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
}

const { title, description, canonical } = Astro.props;

const defaultSiteConfig = {
	id: 1,
	identity: {
		site_name: 'My Site',
		logo_path: null,
		logo_media_key: null,
		logo_thumb_path: null,
		logo_alt_text: null,
	},
	brand: {
		site_name_font: null,
	},
	theme: {},
	seo_defaults: {
		title: null,
		description: null,
	},
} satisfies SiteConfig;

let siteConfig: SiteConfig = defaultSiteConfig;
let navItems: NavItem[] = [];
let headerNav: HeaderNavSettings | null = null;
let footer: FooterSettings | null = null;
const isAdminPage = Astro.url.pathname.startsWith('/admin') && !Astro.url.pathname.startsWith('/admin/auth');

try {
	const composed = isAdminPage
		? await loadAdminLayoutConfig(Astro)
		: await loadPublicLayoutConfig(Astro);
	siteConfig = composed.site;
	headerNav = composed.headerNav;
	footer = composed.footer;
	navItems = composed.navItems;
} catch {
	siteConfig = defaultSiteConfig;
	headerNav = null;
	footer = null;
	navItems = [];
}

const pageTitle =
	title ||
	siteConfig.seo_defaults.title ||
	siteConfig.identity.site_name;

const pageDescription =
	description ||
	siteConfig.seo_defaults.description ||
	siteConfig.identity.site_name;

const canonicalUrl = canonical ?? Astro.url.href;

const resolvedTheme = resolveSiteTheme(siteConfig.theme);
const defaultThemeVars = siteThemeStyleVars(DEFAULT_SITE_THEME);
const themeVars = siteThemeStyleVars(resolvedTheme);
let orionMessages: Record<string, string> = {};

function inheritSiteThemeHeaderNavSettings(settings: HeaderNavSettings | null): HeaderNavSettings | null {
	if (!settings) return settings;
	return {
		...settings,
		background_color: null,
		brand_font_color: null,
		nav_font_color: null,
		nav_hover_color: null,
		border_color: null,
	};
}

function inheritSiteThemeFooterSettings(settings: FooterSettings | null): FooterSettings | null {
	if (!settings) return settings;
	return {
		...settings,
		background_color: null,
		text_color: null,
		border_color: null,
	};
}

const headerNavPreview = inheritSiteThemeHeaderNavSettings(headerNav);
const footerPreview = inheritSiteThemeFooterSettings(footer);

if (isAdminPage) {
	try {
		const adminContext = await loadAdminContext(Astro, [
			'admin/index/actions',
			'admin/orion/assistant',
			'admin/orion/admin_home',
			'admin/orion/site_profile',
			'admin/orion/site_config',
			'admin/orion/header_nav',
			'admin/site_profile/starter_setup',
		]);
		orionMessages = adminContext.messages;
	} catch {
		orionMessages = {};
	}
}
---

<!doctype html>
<html lang="en" style={themeVars}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<style is:global set:html={`:root { ${defaultThemeVars}; }`}></style>

		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:type" content="website" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />

		<script type="application/ld+json">
			{JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'LocalBusiness',
				name: siteConfig.identity.site_name,
				url: Astro.url.origin,
				address: {
					'@type': 'PostalAddress',
					addressLocality: 'Austin',
					addressRegion: 'TX',
					addressCountry: 'US',
				},
			})}
		</script>

		<slot name="head" />
	</head>

	<body>
		<HeaderNav
			siteName={siteConfig.identity.site_name}
			siteNameFont={resolvedTheme.fonts.brand}
			logoPath={siteConfig.identity.logo_path ?? ''}
			navItems={navItems}
			headerNav={headerNavPreview}
		/>

		<main>
			<slot />
		</main>

		<CmsFooter
			siteName={siteConfig.identity.site_name}
			siteNameFont={resolvedTheme.fonts.brand}
			logoPath={siteConfig.identity.logo_path ?? ''}
			navItems={navItems}
			footer={footerPreview}
		/>

		{isAdminPage ? <OrionAssistant pathname={Astro.url.pathname} messages={orionMessages} /> : null}
	</body>
</html>
