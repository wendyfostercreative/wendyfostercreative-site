---
import AdminField from '../../../../components/admin/fields/Field.astro';
import AdminSelect from '../../../../components/admin/fields/Select.astro';

import type { SiteProfile } from '../../../siteProfile/core/types';

type Props = {
	profile: SiteProfile;
	t: (key: string, fallback: string) => string;
};

const { profile, t } = Astro.props;
---

<div class="grid gap-4">
	<AdminField label={t('admin.index.site_profile.admin_language', 'Admin language')} forId="admin_locale">
		<AdminSelect id="admin_locale" name="admin_locale">
			<option value="en" selected={profile.localization.admin_locale === 'en'}>
				{t('admin.index.site_profile.language_en', 'English')}
			</option>
			<option value="de" selected={profile.localization.admin_locale === 'de'}>
				{t('admin.index.site_profile.language_de', 'Deutsch')}
			</option>
		</AdminSelect>
	</AdminField>
</div>
