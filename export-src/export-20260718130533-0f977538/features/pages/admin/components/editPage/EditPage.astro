---
import AdminAlert from '../../../../../components/admin/alerts/Alert.astro';
import AdminCard from '../../../../../components/admin/cards/Card.astro';
import PageEditorSummary from './PageEditorSummary.astro';
import PageSettingsSection from './PageSettingsSection.astro';
import PageSeoSection from './PageSeoSection.astro';
import PageContentSection from './PageContentSection.astro';
import PageEditorActions from './PageEditorActions.astro';
import ImagesPageHeaderEditor from '../../../templates/media/admin/pageHeaderEditor.astro';
import ImagesSeoEditor from '../../../templates/media/admin/seoEditor.astro';

import type { AdminMediaImageItem } from '../../../../media/core/types';
import type { MediaCollectionOption } from '../../../../media/core/collections';
import type { SiteProfile } from '../../../../siteProfile/core/types';
import type { CmsPage, CmsPageTemplateMetadata } from '../../../core/types';

type Props = {
	page: CmsPage;
	templateMeta: CmsPageTemplateMetadata;
	templateLabel: string;
	selectedContent: Record<string, unknown>;
	normalizedPath: string;
	reservedPathReason?: string;
	images: AdminMediaImageItem[];
	collectionOptions?: MediaCollectionOption[];
	siteProfile?: SiteProfile;
	statusMessage?: string;
	errorMessage?: string;
	t: (key: string, fallback: string) => string;
};

const {
	page,
	templateMeta,
	templateLabel,
	selectedContent,
	normalizedPath,
	reservedPathReason = '',
	images,
	collectionOptions = [],
	siteProfile,
	statusMessage = '',
	errorMessage = '',
	t,
} = Astro.props;
const usesPageSectionsTemplate = page.template === 'home' || page.template === 'content' || page.template === 'contact';

---

{errorMessage && (
	<AdminAlert variant="error">
		{errorMessage}
	</AdminAlert>
)}

{!errorMessage && statusMessage && (
	<AdminAlert variant="success">
		{statusMessage}
	</AdminAlert>
)}

<AdminCard>
	<PageEditorSummary page={page} templateLabel={templateLabel} t={t} />
</AdminCard>

<form
	class="grid gap-6"
	method="POST"
	action="/admin/action/pages/update"
	data-image-template-editor={page.template === 'media' ? '' : undefined}
>
	<input type="hidden" name="id" value={page.id} />

	<AdminCard>
		<PageSettingsSection
			page={page}
			normalizedPath={normalizedPath}
			reservedPathReason={reservedPathReason}
			t={t}
		/>
	</AdminCard>

	{page.template === 'media' ? (
		<AdminCard>
			<ImagesPageHeaderEditor page={page} t={t} />
		</AdminCard>
	) : null}

	{usesPageSectionsTemplate ? (
		<PageContentSection
			page={page}
			templateMeta={templateMeta}
			selectedContent={selectedContent}
			images={images}
			collectionOptions={collectionOptions}
			siteProfile={siteProfile}
			t={t}
		/>
	) : (
		<AdminCard>
			<PageContentSection
				page={page}
				templateMeta={templateMeta}
				selectedContent={selectedContent}
				images={images}
				collectionOptions={collectionOptions}
				siteProfile={siteProfile}
				t={t}
			/>
		</AdminCard>
	)}

	<AdminCard>
		{page.template === 'media' ? (
			<ImagesSeoEditor page={page} t={t} />
		) : (
			<PageSeoSection page={page} t={t} />
		)}
	</AdminCard>

	<AdminCard>
		<PageEditorActions t={t} />
	</AdminCard>
</form>
