---
import type { CmsTemplateCardDefinition } from '../../../core/templates';

type Props = {
	fieldName: string;
	inputIdPrefix?: string;
	templates: CmsTemplateCardDefinition[];
	selectedValue?: string;
	required?: boolean;
};

const {
	fieldName,
	inputIdPrefix = 'template',
	templates,
	selectedValue = '',
	required = false,
} = Astro.props;
---

<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
	{templates.map((template, index) => {
		const id = `${inputIdPrefix}-${template.value}`;
		const kind = template.preview;
		const checked = template.value === selectedValue;
		return (
			<label class="block cursor-pointer" for={id}>
				<input
					class="peer sr-only"
					type="radio"
					id={id}
					name={fieldName}
					value={template.value}
					required={required && index === 0}
					checked={checked}
				/>

				<div class="flex h-full flex-col gap-3 rounded-[var(--site-radius-card)] border border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] p-4 text-[var(--admin-color-field-text)] transition peer-checked:border-[var(--site-color-border)] peer-checked:ring-2 peer-checked:ring-[var(--site-color-border)]">
					<div class="overflow-hidden rounded-[var(--site-radius-input)] border border-[var(--admin-color-field-border)] bg-[var(--admin-color-disabled-bg)] p-3">
						{kind === 'home' ? (
							<div class="grid gap-2">
								<div class="h-3 w-16 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-border)]"></div>
								<div class="h-4 w-28 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-placeholder)] opacity-50"></div>
								<div class="h-2 w-full rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-border)]"></div>
								<div class="h-2 w-4/5 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-border)]"></div>
							</div>
						) : kind === 'content' ? (
							<div class="grid gap-2">
								<div class="mx-auto h-3 w-24 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-placeholder)] opacity-50"></div>
								<div class="mx-auto h-2 w-full max-w-[12rem] rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-border)]"></div>
								<div class="mx-auto h-2 w-full max-w-[11rem] rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-border)]"></div>
							</div>
						) : kind === 'media' ? (
							<div class="grid grid-cols-3 gap-2">
								<div class="h-10 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-placeholder)] opacity-50"></div>
								<div class="h-10 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-placeholder)] opacity-50"></div>
								<div class="h-10 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-placeholder)] opacity-50"></div>
							</div>
						) : (
							<div class="grid gap-2">
								<div class="h-3 w-20 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-placeholder)] opacity-50"></div>
								<div class="h-2 w-full rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-border)]"></div>
								<div class="h-2 w-4/5 rounded-[var(--site-radius-input)] bg-[var(--admin-color-field-border)]"></div>
							</div>
						)}
					</div>

					<div>
						<div class="text-sm font-medium text-[var(--admin-color-field-text)]">{template.label}</div>
						{template.description ? (
							<p class="mt-1 text-xs text-[var(--admin-color-field-placeholder)]">{template.description}</p>
						) : null}
					</div>
				</div>
			</label>
		);
	})}
</div>
