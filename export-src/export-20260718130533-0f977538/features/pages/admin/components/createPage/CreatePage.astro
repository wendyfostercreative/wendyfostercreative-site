---
import AdminCard from '../../../../../components/admin/cards/Card.astro';
import PageCreateSection from './PageCreateSection.astro';
import PageListSection from './PageListSection.astro';
import PageStatusMessage from './PageStatusMessage.astro';

import type { CmsPage } from '../../../core/types';
import type { CmsTemplateCardDefinition } from '../../../core/templates';

type Props = {
	pages: CmsPage[];
	templates: CmsTemplateCardDefinition[];
	openCreate: boolean;
	statusMessage?: string;
	errorMessage?: string;
	t: (key: string, fallback: string) => string;
};

const {
	pages,
	templates,
	openCreate,
	statusMessage = '',
	errorMessage = '',
	t,
} = Astro.props;
---

<PageStatusMessage statusMessage={statusMessage} errorMessage={errorMessage} />

<div class="grid gap-6">
	<AdminCard>
		<PageCreateSection templates={templates} openCreate={openCreate} t={t} />
	</AdminCard>

	<AdminCard>
		<PageListSection pages={pages} t={t} />
	</AdminCard>
</div>
