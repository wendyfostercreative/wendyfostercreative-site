---
import AdminSection from '../../../../../components/admin/layout/Section.astro';

import type { CmsPage } from '../../../core/types';

type Props = {
	pages: CmsPage[];
	t: (key: string, fallback: string) => string;
};

const { pages, t } = Astro.props;

function getTemplateLabel(template: string): string {
	const value = String(template || '').trim().toLowerCase();
	return value ? t(`admin.pages.templates.${value}.label`, value) : t('admin.pages.list.unknown', 'unknown');
}
---

<AdminSection
	title={t('admin.pages.list.title', 'Pages')}
	description={t('admin.pages.list.description', 'Select an existing page to continue editing it.')}
>
	{pages.length ? (
		<div class="grid gap-3">
			{pages.map((page) => (
				<a
					href={`/admin/pages/${encodeURIComponent(String(page.id))}`}
					class="grid gap-2 rounded-[var(--site-radius-card)] border border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] p-4 text-sm text-[var(--admin-color-field-text)] hover:border-[var(--site-color-border)]"
				>
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<div class="font-medium">{page.title || t('admin.pages.list.untitled', 'Untitled Page')}</div>
							<div class="truncate text-[var(--admin-color-field-placeholder)]">{page.path}</div>
						</div>
						<div class="shrink-0 text-right text-xs text-[var(--admin-color-field-placeholder)]">
							<div>{page.published ? t('admin.pages.list.published', 'Published') : t('admin.pages.list.draft', 'Draft')}</div>
						</div>
					</div>

					<div class="text-xs text-[var(--admin-color-field-placeholder)]">
						<span class="font-medium text-[var(--admin-color-field-text)]">{t('admin.pages.list.template', 'Template:')}</span> {getTemplateLabel(page.template)}
					</div>
				</a>
			))}
		</div>
	) : (
		<div class="grid gap-3 rounded-[var(--site-radius-card)] border border-dashed border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] p-4 text-sm text-[var(--admin-color-field-placeholder)]">
			<div class="font-medium text-[var(--admin-color-field-text)]">{t('admin.pages.list.empty_title', 'No pages yet')}</div>
			<div>{t('admin.pages.list.empty_body', 'Create your first page above, then continue editing it in the dedicated page editor.')}</div>
		</div>
	)}
</AdminSection>
