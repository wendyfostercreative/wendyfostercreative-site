---
import Layout from '../../../../layouts/BaseLayout.astro';
import CmsPageNotFound from './CmsPageNotFound.astro';

import { cmsTemplateRegistry } from '../registry';
import { getCmsPageByPath } from '../api';
import { getSiteConfig } from '../../../siteConfig/public/api';
import type { CmsPage } from '../../core/types';
import type { SiteConfig } from '../../../siteConfig/core/types';

interface Props {
	path: string;
	apiBaseUrl?: string;
	canonical?: string;
}

const { path, apiBaseUrl, canonical } = Astro.props as Props;

let site: SiteConfig | null = null;
let page: CmsPage | null = null;

try {
	site = await getSiteConfig({ apiBaseUrl });
} catch {
	site = null;
}

try {
	page = await getCmsPageByPath(path, { apiBaseUrl });
} catch {
	page = null;
}

if (!page) {
	Astro.response.status = 404;
}

const templateKey =
	typeof page?.template === 'string' ? page.template.trim().toLowerCase() : '';

const TemplateComponent = templateKey
	? cmsTemplateRegistry[templateKey as keyof typeof cmsTemplateRegistry]
	: undefined;

if (page && !TemplateComponent) {
	throw new Error(`Unknown CMS template: ${page.template}`);
}

const resolvedSite: SiteConfig = site ?? {
	id: 1,
	identity: {
		site_name: 'My Site',
		logo_path: null,
		logo_alt_text: null,
	},
	brand: {
		site_name_font: null,
	},
	theme: {},
	seo_defaults: {
		title: null,
		description: null,
	},
};

const title =
	page?.seo_title ||
	resolvedSite.seo_defaults.title ||
	page?.title ||
	resolvedSite.identity.site_name;

const description =
	page?.seo_description ||
	resolvedSite.seo_defaults.description ||
	'';
---

<Layout title={title} description={description} canonical={canonical}>
	{page && TemplateComponent ? (
		<TemplateComponent page={page} site={resolvedSite} apiBaseUrl={apiBaseUrl} />
	) : (
		<CmsPageNotFound path={path} />
	)}
</Layout>
