---
import HeaderNav from '../../../headerNav/public/components/HeaderNav.astro';
import type { HeaderNavSettings, NavItem } from '../../../headerNav/core/types';

interface Props {
	siteName: string;
	siteNameFont?: string | null;
	logoPath: string;
	navItems: NavItem[];
	headerNav?: HeaderNavSettings | null;
}

const { siteName, siteNameFont, logoPath, navItems, headerNav } = Astro.props as Props;
---

<HeaderNav
	siteName={siteName}
	siteNameFont={siteNameFont}
	logoPath={logoPath}
	navItems={navItems}
	headerNav={headerNav}
/>
