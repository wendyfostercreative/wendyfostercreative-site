---
import AdminCard from '../../../../components/admin/cards/Card.astro';
import AdminField from '../../../../components/admin/fields/Field.astro';
import AdminSelect from '../../../../components/admin/fields/Select.astro';
import AdminSection from '../../../../components/admin/layout/Section.astro';
import Button from '../../../../components/ui/Button.astro';

import type { PageSectionRegistry } from '../core/types';
type Props = { registry: PageSectionRegistry };
const { registry } = Astro.props as Props;
const definitions = Object.values(registry);
const firstDefinition = definitions[0];
---
<AdminCard as="section" data-section-picker-card>
	<AdminSection
		title="Section picker"
		description="Create a new page section. Choose a section type, then choose a layout."
	>
		<div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_minmax(14rem,18rem)]">
			<div class="grid gap-4">
				<AdminField label="Section type" forId="sectionTypeSelect">
					<AdminSelect id="sectionTypeSelect" includeName={false} data-section-type-select>
						{definitions.map((definition) => <option value={definition.type}>{definition.label}</option>)}
					</AdminSelect>
				</AdminField>

				<AdminField label="Layout" forId="sectionLayoutSelect">
					<AdminSelect id="sectionLayoutSelect" includeName={false} data-section-layout-select>
						{firstDefinition?.layouts.map((layout) => <option value={layout.key}>{layout.label}</option>)}
					</AdminSelect>
				</AdminField>

				<div class="rounded-[var(--site-radius-card)] border border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] p-3 text-sm text-[var(--site-color-text-muted)]" data-section-description>
					{firstDefinition?.description || 'Choose a section type.'}
				</div>

				<Button type="button" class="w-fit" data-add-page-section>
					Add section
				</Button>
			</div>

			<div class="grid gap-2 rounded-[var(--site-radius-card)] border border-dashed border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] p-3" data-layout-preview>
				<div class="text-xs font-semibold uppercase tracking-wide text-[var(--site-color-text-muted)]">Layout preview</div>
				<div class="grid min-h-32 place-items-center rounded-[var(--site-radius-input)] bg-[var(--site-color-bg-soft)] p-4" data-layout-preview-art aria-hidden="true">
					<div class="grid w-full max-w-44 gap-2 text-center">
						<div class="mx-auto h-3 w-16 rounded bg-[var(--site-color-border-soft)]"></div>
						<div class="h-4 rounded bg-[var(--site-color-text)] opacity-20"></div>
						<div class="mx-auto h-3 w-24 rounded bg-[var(--site-color-border-soft)]"></div>
						<div class="mx-auto h-7 w-20 rounded bg-[var(--site-color-button-bg)] opacity-60"></div>
					</div>
				</div>
				<div class="text-xs text-[var(--site-color-text-muted)]" data-layout-description>{firstDefinition?.layouts[0]?.description || ''}</div>
			</div>
		</div>
	</AdminSection>
</AdminCard>
