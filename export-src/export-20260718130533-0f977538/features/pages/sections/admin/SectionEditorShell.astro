---
import AdminCard from '../../../../components/admin/cards/Card.astro';
import AdminField from '../../../../components/admin/fields/Field.astro';
import AdminSelect from '../../../../components/admin/fields/Select.astro';
import AdminSection from '../../../../components/admin/layout/Section.astro';
import type { PageSection, PageSectionRegistry } from '../core/types';
import SectionActions from './SectionActions.astro';
import HeroSectionEditor from '../../templates/home/sections/admin/HeroSectionEditor.astro';
import ImageLinkTextEditor from '../../templates/home/sections/admin/ImageLinkTextEditor.astro';
import ContentHeroSectionEditor from '../../templates/content/sections/admin/ContentHeroSectionEditor.astro';
import RichTextSectionEditor from '../../templates/content/sections/admin/RichTextSectionEditor.astro';
import ContentImageLinkTextEditor from '../../templates/content/sections/admin/ImageLinkTextSectionEditor.astro';
import ThumbnailGridSectionEditor from '../../templates/content/sections/admin/ThumbnailGridSectionEditor.astro';
import ContactIntroSectionEditor from '../../templates/contact/sections/admin/ContactIntroSectionEditor.astro';
import ContactDetailsSectionEditor from '../../templates/contact/sections/admin/ContactDetailsSectionEditor.astro';
import ContactFormBlockSectionEditor from '../../templates/contact/sections/admin/ContactFormBlockSectionEditor.astro';

type Props = { sections: PageSection[]; registry: PageSectionRegistry; template: string };
const { sections, registry, template } = Astro.props as Props;
function preview(section: PageSection): string {
	const definition = registry[section.type];
	return definition?.summarize(section) || section.type;
}
function layoutLabel(section: PageSection): string {
	const definition = registry[section.type];
	return definition?.layouts.find((layout) => layout.key === section.layout)?.label || section.layout;
}
function imageStatus(section: PageSection): string {
	const thumbnails = Array.isArray(section.content.thumbnails) ? section.content.thumbnails : [];
	if (thumbnails.length) {
		const count = thumbnails.filter((item) => {
			const raw = item && typeof item === 'object' ? item as Record<string, unknown> : {};
			const image = raw.image && typeof raw.image === 'object' ? raw.image as Record<string, unknown> : {};
			return Boolean(image.path);
		}).length;
		return count ? `${count} thumbnail${count === 1 ? '' : 's'}` : 'No thumbnails';
	}
	const image = section.content.image as Record<string, unknown> | undefined;
	return image?.path ? 'Image set' : 'No image';
}
function actionStatus(section: PageSection): string {
	const image = section.content.image as Record<string, unknown> | undefined;
	const imageLink = image?.link as Record<string, unknown> | undefined;
	const imageLinkCount = imageLink?.href ? 1 : 0;
	const thumbnailLinks = Array.isArray(section.content.thumbnails) ? section.content.thumbnails.filter((item) => {
		const raw = item && typeof item === 'object' ? item as Record<string, unknown> : {};
		const link = raw.link && typeof raw.link === 'object' ? raw.link as Record<string, unknown> : {};
		return Boolean(link.href);
	}).length : 0;
	const keys = section.type === 'hero' ? ['primary_action', 'secondary_action'] : section.type === 'content_hero' ? ['primary_action'] : [];
	const count = keys.filter((key) => {
		const action = section.content[key] as Record<string, unknown> | undefined;
		return Boolean(action?.label && action?.href);
	}).length + imageLinkCount + thumbnailLinks;
	return count > 0 ? `${count} link${count === 1 ? '' : 's'}` : 'No link';
}
---
<AdminCard as="section" data-section-editor-card-shell>
	<AdminSection
		title="Section editor"
		description="Manage existing sections. Open one section at a time to edit its fields."
	>
		<div class:list={['rounded-[var(--site-radius-card)] border border-dashed border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] p-6 text-sm text-[var(--site-color-text-muted)]', sections.length > 0 ? 'hidden' : '']} data-section-empty-state>
			Add a section to start building this page.
		</div>

		<div class="grid gap-3" data-page-section-list>
			{sections.map((section, index) => (
				<div class:list={['grid gap-3 rounded-[var(--site-radius-card)] border bg-[var(--admin-color-field-bg)] p-4 text-left transition', index === 0 ? 'border-[var(--site-color-text)] shadow-sm' : 'border-[var(--admin-color-field-border)]']} role="button" tabindex="0" data-page-section data-section-id={section.id} data-section-type={section.type} data-section-layout={section.layout} data-active={index === 0 ? 'true' : 'false'}>
					<div class="grid gap-2" data-section-summary-panel>
						<div class="flex flex-wrap items-start justify-between gap-3">
							<div>
								<div class="text-sm font-semibold"><span data-section-number>{index + 1}</span>. <span data-section-label>{registry[section.type]?.label || section.type}</span></div>
								<div class="text-xs text-[var(--site-color-text-muted)]" data-section-layout-label>{layoutLabel(section)}</div>
							</div>
							<SectionActions index={index} isFirst={index === 0} isLast={index === sections.length - 1} />
						</div>
						<div class="text-sm text-[var(--site-color-text-muted)]" data-section-summary>{preview(section)}</div>
						<div class="flex flex-wrap gap-2 text-xs text-[var(--site-color-text-muted)]">
							<span class="rounded-full border border-[var(--admin-color-field-border)] px-2 py-1" data-section-image-status>{imageStatus(section)}</span>
							<span class="rounded-full border border-[var(--admin-color-field-border)] px-2 py-1" data-section-action-status>{actionStatus(section)}</span>
						</div>
					</div>

					<div class:list={['grid gap-4 border-t border-[var(--admin-color-field-border)] pt-4', index === 0 ? '' : 'hidden']} data-section-editor-card data-section-id={section.id} data-section-type={section.type} data-section-layout={section.layout} data-active={index === 0 ? 'true' : 'false'}>
						<div class="grid gap-2 md:grid-cols-[1fr_14rem] md:items-end">
							<div>
								<div class="text-sm font-semibold">Edit {registry[section.type]?.label || section.type}</div>
								<div class="text-xs text-[var(--site-color-text-muted)]">Section ID: {section.id}</div>
							</div>
							<AdminField label="Layout" forId={`section-layout-${section.id}`}>
								<AdminSelect id={`section-layout-${section.id}`} includeName={false} density="compact" data-section-layout-select>
									{(registry[section.type]?.layouts || [{ key: section.layout, label: section.layout }]).map((layout) => (
										<option value={layout.key} selected={layout.key === section.layout}>{layout.label}</option>
									))}
								</AdminSelect>
							</AdminField>
						</div>
						{template === 'content' && section.type === 'content_hero' ? (
							<ContentHeroSectionEditor section={section} index={index} />
						) : template === 'content' && section.type === 'rich_text' ? (
							<RichTextSectionEditor section={section} index={index} />
						) : template === 'content' && section.type === 'image_link_text' ? (
							<ContentImageLinkTextEditor section={section} index={index} />
						) : template === 'content' && section.type === 'thumbnail_grid' ? (
							<ThumbnailGridSectionEditor section={section} index={index} />
						) : template === 'contact' && section.type === 'contact_intro' ? (
							<ContactIntroSectionEditor section={section} index={index} />
						) : template === 'contact' && section.type === 'contact_details' ? (
							<ContactDetailsSectionEditor section={section} index={index} />
						) : template === 'contact' && section.type === 'contact_form_block' ? (
							<ContactFormBlockSectionEditor section={section} index={index} />
						) : section.type === 'hero' ? (
							<HeroSectionEditor section={section} index={index} />
						) : section.type === 'image_link_text' ? (
							<ImageLinkTextEditor section={section} index={index} />
						) : (
							<div class="rounded border border-dashed p-3 text-sm text-[var(--site-color-text-muted)]">No editor for {section.type}.</div>
						)}
					</div>
				</div>
			))}
		</div>
	</AdminSection>
</AdminCard>
