---
import PageContainer from '../../../../../../components/public/PageContainer.astro';
import SectionHeading from '../../../../../../components/public/SectionHeading.astro';
import SectionShell from '../../../../../../components/public/SectionShell.astro';
import type { PageSection } from '../../../../sections/core/types';

type Props = { section: PageSection };
const { section } = Astro.props as Props;
const content = (section.content || {}) as Record<string, any>;
const alignment = section.layout.endsWith('.left') ? 'left' : section.layout.endsWith('.right') ? 'right' : 'center';
const positionClass = alignment === 'left'
	? 'mr-auto'
	: alignment === 'right'
		? 'ml-auto'
		: 'mx-auto';
---
<SectionShell spacing="default">
	<PageContainer width="site">
		<SectionHeading
			eyebrow={content.eyebrow}
			heading={content.heading}
			body={content.body}
			as="h1"
			size="hero"
			align={alignment}
			class={positionClass}
		/>
	</PageContainer>
</SectionShell>
