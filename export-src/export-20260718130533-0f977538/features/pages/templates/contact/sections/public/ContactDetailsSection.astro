---
import PageContainer from '../../../../../../components/public/PageContainer.astro';
import PublicPanel from '../../../../../../components/public/PublicPanel.astro';
import SectionShell from '../../../../../../components/public/SectionShell.astro';
import type { PageSection } from '../../../../sections/core/types';

type Props = { section: PageSection };
const { section } = Astro.props as Props;
const content = (section.content || {}) as Record<string, any>;
const email = String(content.email || '').trim();
const phone = String(content.phone || '').trim();
const location = String(content.location || '').trim();
const hasContactDetail = Boolean(email || phone || location);
const phoneHref = phone ? phone.replace(/[^+0-9]/g, '') : '';
const alignment = section.layout.endsWith('.left') ? 'left' : section.layout.endsWith('.right') ? 'right' : 'center';
const alignmentClass = alignment === 'left'
	? 'mr-auto text-left'
	: alignment === 'right'
		? 'ml-auto text-right'
		: 'mx-auto text-center';
---
<SectionShell spacing="compact">
	<PageContainer width="site">
		<PublicPanel class:list={['grid w-full max-w-[var(--site-content-width)] gap-4', alignmentClass]}>
			{hasContactDetail ? (
				<>
					{email ? <div><div class="text-xs font-semibold uppercase tracking-wide text-[var(--site-color-text-muted)]">Email</div><a class="mt-1 block text-sm underline" href={`mailto:${email}`}>{email}</a></div> : null}
					{phone ? <div><div class="text-xs font-semibold uppercase tracking-wide text-[var(--site-color-text-muted)]">Phone</div><a class="mt-1 block text-sm underline" href={`tel:${phoneHref}`}>{phone}</a></div> : null}
					{location ? <div><div class="text-xs font-semibold uppercase tracking-wide text-[var(--site-color-text-muted)]">Location</div><p class="mt-1 whitespace-pre-line text-sm leading-6">{location}</p></div> : null}
				</>
			) : (
				<p class="text-sm text-[var(--site-color-text-muted)]">Contact details are coming soon.</p>
			)}
		</PublicPanel>
	</PageContainer>
</SectionShell>
