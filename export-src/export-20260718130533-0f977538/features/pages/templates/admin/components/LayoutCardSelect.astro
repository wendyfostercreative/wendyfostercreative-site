---
export type LayoutCardOption = {
	value: string;
	label: string;
	ui?: string;
};

type Props = {
	fieldName: string;
	fieldValue: string;
	options: LayoutCardOption[];
};

const { fieldName, fieldValue, options } = Astro.props;

const layoutDisplayOrder = ['image-left', 'centered', 'image-right'];
const orderedOptions = [...options].sort((a, b) => {
	const aIndex = layoutDisplayOrder.indexOf(a.value);
	const bIndex = layoutDisplayOrder.indexOf(b.value);

	if (aIndex === -1 && bIndex === -1) return 0;
	if (aIndex === -1) return 1;
	if (bIndex === -1) return -1;

	return aIndex - bIndex;
});
---

<div class="grid gap-3">
	<div class="grid gap-3 sm:grid-cols-3">
		{orderedOptions.map((option) => (
			<label class="block cursor-pointer">
				<input
					class="peer sr-only"
					type="radio"
					name={fieldName}
					value={option.value}
					checked={option.value === fieldValue || (!fieldValue && option.value === 'centered')}
				/>

				<div
					class="rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-white p-3 text-[var(--site-color-text)] transition peer-checked:border-[var(--site-color-border)] peer-checked:ring-2 peer-checked:ring-[var(--site-color-border)]"
				>
					<div class="text-sm font-medium text-[var(--site-color-text)]">{option.label}</div>

					<div
						class="mt-3 overflow-hidden rounded-[var(--site-radius-input)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-panel)] p-3"
					>
						{option.value === 'image-left' ? (
							<div class="grid grid-cols-[40%_1fr] gap-2">
								<div class="min-h-[72px] rounded-[var(--site-radius-input)] bg-[var(--site-color-border)] opacity-50"></div>
								<div class="grid gap-2">
									<div class="h-3 w-16 rounded-[var(--site-radius-input)] bg-[var(--site-color-border)] opacity-50"></div>
									<div class="h-2 w-full rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
									<div class="h-2 w-full rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
									<div class="h-2 w-4/5 rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
								</div>
							</div>
						) : option.value === 'centered' ? (
							<div class="flex min-h-[72px] items-center justify-center">
								<div class="grid w-full gap-2">
									<div class="mx-auto h-3 w-24 rounded-[var(--site-radius-input)] bg-[var(--site-color-border)] opacity-50"></div>
									<div class="mx-auto h-2 w-full max-w-[10rem] rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
									<div class="mx-auto h-2 w-full max-w-[9rem] rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
									<div class="mx-auto h-2 w-full max-w-[8rem] rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
								</div>
							</div>
						) : option.value === 'image-right' ? (
							<div class="grid grid-cols-[1fr_40%] gap-2">
								<div class="grid gap-2">
									<div class="h-3 w-16 rounded-[var(--site-radius-input)] bg-[var(--site-color-border)] opacity-50"></div>
									<div class="h-2 w-full rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
									<div class="h-2 w-full rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
									<div class="h-2 w-4/5 rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
								</div>
								<div class="min-h-[72px] rounded-[var(--site-radius-input)] bg-[var(--site-color-border)] opacity-50"></div>
							</div>
						) : (
							<div class="flex min-h-[72px] items-center justify-center">
								<div class="grid w-full gap-2">
									<div class="mx-auto h-3 w-24 rounded-[var(--site-radius-input)] bg-[var(--site-color-border)] opacity-50"></div>
									<div class="mx-auto h-2 w-full max-w-[10rem] rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
									<div class="mx-auto h-2 w-full max-w-[9rem] rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
									<div class="mx-auto h-2 w-full max-w-[8rem] rounded-[var(--site-radius-input)] bg-[var(--site-color-border-soft)]"></div>
								</div>
							</div>
						)}
					</div>
				</div>
			</label>
		))}
	</div>
</div>
