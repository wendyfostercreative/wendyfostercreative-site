---
import LayoutCardSelect from './LayoutCardSelect.astro';
import ImagePathPicker from '../../../../media/images/admin/components/ImagePathPicker.astro';
import AdminInput from '../../../../../components/admin/fields/Input.astro';
import AdminSelect from '../../../../../components/admin/fields/Select.astro';
import AdminTextarea from '../../../../../components/admin/fields/Textarea.astro';

import type { AdminMediaImageItem } from '../../../../media/core/types';
import type { CmsTemplateField } from '../../../core/types';

type Props = {
	field: CmsTemplateField;
	fieldValue: string;
	inputId: string;
	fieldName: string;
	images: AdminMediaImageItem[];
	t?: (key: string, fallback: string) => string;
};

const { field, fieldValue, inputId, fieldName, images, t } = Astro.props;

const shouldUseLayoutCards =
	field.input === 'select' &&
	(field.ui === 'layout-card' ||
		field.name === 'layout_variant' ||
		(field.options ?? []).some((option) => option.ui === 'layout-card'));
---

<div class="grid gap-2">
	{field.name === 'image_path' ? (
		<ImagePathPicker fieldName={fieldName} fieldValue={fieldValue} images={images} t={t} />
	) : field.input === 'textarea' ? (
		<AdminTextarea
			id={inputId}
			name={fieldName}
			rows={field.rows ?? 4}
			value={fieldValue}
			placeholder={field.placeholder ?? ''}
		/>
	) : shouldUseLayoutCards ? (
		<LayoutCardSelect fieldName={fieldName} fieldValue={fieldValue} options={field.options ?? []} />
	) : field.input === 'select' ? (
		<AdminSelect id={inputId} name={fieldName}>
			{(field.options ?? []).map((option) => (
				<option value={option.value} selected={option.value === fieldValue}>
					{option.label}
				</option>
			))}
		</AdminSelect>
	) : (
		<AdminInput
			id={inputId}
			name={fieldName}
			type={field.input === 'email' ? 'email' : 'text'}
			value={fieldValue}
			placeholder={field.placeholder ?? ''}
		/>
	)}

	{field.description ? <p class="text-xs text-[var(--site-color-text-muted)]">{field.description}</p> : null}
</div>
