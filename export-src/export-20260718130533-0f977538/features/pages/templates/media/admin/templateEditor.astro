---
import DisplayEditor from './display/displayEditor.astro';
import LinksEditor from './links/linksEditor.astro';
import PageHeaderEditor from './pageHeaderEditor.astro';
import SourceEditor from './source/sourceEditor.astro';

import { normalizeImageTemplateContent } from '../schema/content';
import { mediaCollectionKeyFromPath } from '../../../../media/core/collections';
import type { CmsPage } from '../../../core/types';
import type { MediaCollectionOption } from '../../../../media/core/collections';
import type { SiteProfile } from '../../../../siteProfile/core/types';

type Props = {
	page: CmsPage;
	collectionOptions?: MediaCollectionOption[];
	siteProfile?: SiteProfile;
	t: (key: string, fallback: string) => string;
};

const { page, collectionOptions = [], siteProfile, t } = Astro.props;
const content = normalizeImageTemplateContent(page.content);
const pageCollection = mediaCollectionKeyFromPath(page.path) || content.source.collection;
content.source.mode = 'filtered';
content.source.collection = pageCollection;
const contentJsonInitialValue = JSON.stringify(content, null, 2);
---

<div class="grid gap-6">
	<textarea class="hidden" id="contentJson" name="content_json">{contentJsonInitialValue}</textarea>

	<PageHeaderEditor page={page} t={t} />
	<SourceEditor source={content.source} collectionOptions={collectionOptions} siteProfile={siteProfile} t={t} />
	<DisplayEditor display={content.display} t={t} />
	<LinksEditor links={content.links} t={t} />
</div>

<script>
	import { initImageTemplateEditor } from './templateEditor';
	initImageTemplateEditor();
</script>
