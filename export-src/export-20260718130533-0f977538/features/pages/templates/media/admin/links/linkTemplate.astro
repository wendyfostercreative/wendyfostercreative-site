---
import LinkFields from './linkFields.astro';

import { DEFAULT_IMAGE_GALLERY_LINK } from '../../schema/content';

type Props = {
	t: (key: string, fallback: string) => string;
};

const { t } = Astro.props;
---

<template data-image-link-template>
	<LinkFields index="__new__" link={DEFAULT_IMAGE_GALLERY_LINK} t={t} />
</template>
