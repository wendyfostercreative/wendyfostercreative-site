---
import type { ImageMediaViewItem } from '../../../../../media/images/core/types';
import type { ImageGalleryDisplay } from '../../schema/types';

type Props = {
	items: ImageMediaViewItem[];
	display: ImageGalleryDisplay;
};

const { items, display } = Astro.props as Props;

function thumbnailImageClass(item: ImageMediaViewItem): string {
	if (item.detail_display_preset === 'vertical') {
		return 'mx-auto h-full max-w-[62%] object-contain transition group-hover:opacity-90';
	}
	if (item.detail_display_preset === 'horizontal') {
		return 'mx-auto max-h-[62%] w-full object-contain transition group-hover:opacity-90';
	}
	return 'h-full w-full object-cover transition group-hover:opacity-90';
}
---

<div class="grid grid-cols-2 gap-4 md:grid-cols-3">
	{items.map((item) => (
		<a
			href={item.public_href ?? '#'}
			class="group block overflow-hidden rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-panel)] text-[var(--site-color-text)]"
		>
			<div class="flex aspect-square w-full items-center justify-center bg-[var(--site-color-bg)]">
				<img
					src={item.thumb_path ?? item.file_path}
					alt={item.title ?? ''}
					class={thumbnailImageClass(item)}
				/>
			</div>
			{display.show_title || display.show_description || display.show_price || display.show_collection || display.show_materials ? (
				<div class="grid gap-1 p-3">
					{display.show_title && item.title ? <div class="text-sm font-medium">{item.title}</div> : null}
					{display.show_description && item.description ? <p class="text-sm text-[var(--site-color-text-muted)]">{item.description}</p> : null}
					{display.show_price && item.price ? <div class="text-sm text-[var(--site-color-text)]">{item.price}</div> : null}
					{display.show_collection && item.collection ? <div class="text-xs uppercase tracking-wide text-[var(--site-color-text-muted)]">{item.collection}</div> : null}
					{display.show_materials && item.materials.length > 0 ? (
						<div class="text-xs text-[var(--site-color-text-muted)]">{item.materials.join(', ')}</div>
					) : null}
				</div>
			) : null}
		</a>
	))}
</div>
