---
import type { PageSection } from '../../../../sections/core/types';
import ImagePathPicker from '../../../../../media/images/admin/components/ImagePathPicker.astro';

type Props = { section: PageSection; index: number };
const { section } = Astro.props as Props;
const content = (section.content || {}) as Record<string, any>;
const thumbnails = Array.isArray(content.thumbnails) ? content.thumbnails : [];
const thumbnailItems = Array.from({ length: 10 }, (_, index) => {
	const item = thumbnails[index] && typeof thumbnails[index] === 'object' ? thumbnails[index] as Record<string, any> : {};
	const image = item.image && typeof item.image === 'object' ? item.image as Record<string, any> : {};
	const link = item.link && typeof item.link === 'object' ? item.link as Record<string, any> : {};
	return { image, link };
});
const thumbnailShape = ['natural', 'square', 'wide'].includes(String(content.thumbnail_shape)) ? String(content.thumbnail_shape) : 'square';
---
<div class="grid gap-4" data-section-editor data-section-id={section.id} data-section-type="thumbnail_grid">
	<label class="grid gap-1 text-sm font-medium">Heading
		<input class="rounded border px-3 py-2" data-section-field="heading" value={content.heading || ''} />
	</label>
	<label class="grid gap-1 text-sm font-medium">Body
		<textarea class="rounded border px-3 py-2" rows="3" data-section-field="body">{content.body || ''}</textarea>
	</label>
	<label class="grid gap-1 text-sm font-medium">Thumbnail shape
		<select class="rounded border px-3 py-2" data-section-field="thumbnail_shape">
			<option value="natural" selected={thumbnailShape === 'natural'}>Fit image</option>
			<option value="square" selected={thumbnailShape === 'square'}>Square crop</option>
			<option value="wide" selected={thumbnailShape === 'wide'}>Wide crop</option>
		</select>
	</label>
	<div class="grid gap-3 rounded border border-[var(--site-color-border-soft)] p-3" data-section-thumbnails>
		<div>
			<div class="text-sm font-semibold">Thumbnails</div>
			<p class="text-xs text-[var(--site-color-text-muted)]">Add up to ten linked thumbnails. Empty thumbnail slots will not render publicly.</p>
		</div>
		<div class="grid gap-3 rounded border border-[var(--site-color-border-soft)] p-3" data-section-thumbnail-item data-thumbnail-index="0">
			<div class="flex flex-wrap items-center justify-between gap-2">
				<div class="text-sm font-semibold">Thumbnail <span data-thumbnail-number>1</span></div>
				<div class="flex flex-wrap gap-2">
					<button class="rounded border px-2 py-1 text-xs" type="button" data-thumbnail-move="up">Move up</button>
					<button class="rounded border px-2 py-1 text-xs" type="button" data-thumbnail-move="down">Move down</button>
				</div>
			</div>
			<ImagePathPicker fieldName={`section-${section.id}-thumbnail-0-path`} fieldValue={String(thumbnailItems[0]?.image?.path || '')} thumbFieldName={`section-${section.id}-thumbnail-0-thumb-path`} thumbFieldValue={String(thumbnailItems[0]?.image?.thumb_path || '')} mediaRole="content_image" uploadCollection="content_section" uploadCategory="thumbnail_grid" />
			<label class="grid gap-1 text-sm">Alt text
				<input class="rounded border px-3 py-2" data-thumbnail-image-field="alt" value={thumbnailItems[0]?.image?.alt || ''} />
			</label>
			<div class="grid gap-2 rounded border border-[var(--site-color-border-soft)] p-3" data-thumbnail-link>
				<div class="text-sm font-semibold">Thumbnail link</div>
				<label class="grid gap-1 text-sm">Target
					<select class="rounded border px-3 py-2" data-section-action-field="target_type">
						<option value="external_url" selected={thumbnailItems[0]?.link?.target_type !== 'cms_page'}>External URL</option>
						<option value="cms_page" selected={thumbnailItems[0]?.link?.target_type === 'cms_page'}>CMS page</option>
					</select>
				</label>
				<label class="grid gap-1 text-sm">CMS page ID<input class="rounded border px-3 py-2" type="number" data-section-action-field="page_id" value={thumbnailItems[0]?.link?.page_id ?? ''} /></label>
				<label class="grid gap-1 text-sm">Href<input class="rounded border px-3 py-2" data-section-action-field="href" value={thumbnailItems[0]?.link?.href || ''} placeholder="/gallery" /></label>
