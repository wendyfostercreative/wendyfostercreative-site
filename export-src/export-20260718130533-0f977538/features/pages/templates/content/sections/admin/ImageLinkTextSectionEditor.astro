---
import type { PageSection } from '../../../../sections/core/types';
import ImagePathPicker from '../../../../../media/images/admin/components/ImagePathPicker.astro';

type Props = { section: PageSection; index: number };
const { section } = Astro.props as Props;
const content = (section.content || {}) as Record<string, any>;
const image = (content.image && typeof content.image === 'object') ? content.image as Record<string, any> : {};
const imageLink = (image.link && typeof image.link === 'object') ? image.link as Record<string, any> : {};
const imageShape = ['natural', 'square', 'wide'].includes(String(image.shape)) ? String(image.shape) : 'natural';
---
<div class="grid gap-4" data-section-editor data-section-id={section.id} data-section-type="image_link_text">
	<label class="grid gap-1 text-sm font-medium">Heading
		<input class="rounded border px-3 py-2" data-section-field="heading" value={content.heading || ''} />
	</label>
	<label class="grid gap-1 text-sm font-medium">Body
		<textarea class="rounded border px-3 py-2" rows="4" data-section-field="body">{content.body || ''}</textarea>
	</label>
	<div class="grid gap-2 rounded border border-[var(--site-color-border-soft)] p-3">
		<div class="text-sm font-semibold">Image</div>
		<ImagePathPicker fieldName={`section-${section.id}-image-path`} fieldValue={String(image.path || '')} sectionImageField="path" mediaRole="content_image" uploadCollection="content_section" uploadCategory="image_link_text" />
		<label class="grid gap-1 text-sm">Alt text<input class="rounded border px-3 py-2" data-section-image-field="alt" value={image.alt || ''} /></label>
		<label class="grid gap-1 text-sm">Image shape
			<select class="rounded border px-3 py-2" data-section-image-field="shape">
				<option value="natural" selected={imageShape === 'natural'}>Natural image shape</option>
				<option value="square" selected={imageShape === 'square'}>Square crop</option>
				<option value="wide" selected={imageShape === 'wide'}>Wide crop</option>
			</select>
		</label>
		<div class="grid gap-2 rounded border border-[var(--site-color-border-soft)] p-3" data-section-image-link>
			<div class="text-sm font-semibold">Image click target</div>
			<label class="grid gap-1 text-sm">Target
				<select class="rounded border px-3 py-2" data-section-action-field="target_type">
					<option value="external_url" selected={imageLink.target_type !== 'cms_page'}>External URL</option>
					<option value="cms_page" selected={imageLink.target_type === 'cms_page'}>CMS page</option>
				</select>
			</label>
			<label class="grid gap-1 text-sm">CMS page ID<input class="rounded border px-3 py-2" type="number" data-section-action-field="page_id" value={imageLink.page_id ?? ''} /></label>
			<label class="grid gap-1 text-sm">Href<input class="rounded border px-3 py-2" data-section-action-field="href" value={imageLink.href || ''} placeholder="/gallery" /></label>
		</div>
	</div>
</div>
