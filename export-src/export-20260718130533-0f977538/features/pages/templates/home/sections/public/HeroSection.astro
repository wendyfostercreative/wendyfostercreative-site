---
import ActionGroup from '../../../../../../components/public/ActionGroup.astro';
import MediaFigure from '../../../../../../components/public/MediaFigure.astro';
import PageContainer from '../../../../../../components/public/PageContainer.astro';
import SectionHeading from '../../../../../../components/public/SectionHeading.astro';
import SectionShell from '../../../../../../components/public/SectionShell.astro';
import { resolveCmsImageSrc } from '../../../../../media/images/core/paths';
import type { PageSection } from '../../../../sections/core/types';

type Props = { section: PageSection };
const { section } = Astro.props as Props;
const content = (section.content || {}) as Record<string, any>;
const image = (content.image && typeof content.image === 'object') ? content.image as Record<string, any> : {};
const imageLink = (image.link && typeof image.link === 'object') ? image.link as Record<string, any> : {};
const primary = (content.primary_action && typeof content.primary_action === 'object') ? content.primary_action as Record<string, any> : {};
const secondary = (content.secondary_action && typeof content.secondary_action === 'object') ? content.secondary_action as Record<string, any> : {};
const imageSrc = resolveCmsImageSrc(String(image.path || ''));
const imageShape = (['natural', 'square', 'wide'].includes(String(image.shape)) ? String(image.shape) : 'natural') as 'natural' | 'square' | 'wide';
const hasImage = Boolean(imageSrc);
const imageHref = typeof imageLink.href === 'string' ? imageLink.href.trim() : '';
const imageRight = section.layout === 'hero.image_right';
const centered = !(imageRight && hasImage);
---
<SectionShell spacing="hero">
	<PageContainer class:list={['grid gap-12', !centered ? 'md:grid-cols-[minmax(0,1fr)_minmax(18rem,28rem)] md:items-center' : 'justify-items-center text-center']}>
		<div class:list={['grid max-w-3xl gap-5', centered ? 'justify-items-center' : '']}>
			<SectionHeading
				eyebrow={content.eyebrow}
				heading={content.headline}
				body={content.body}
				as="h1"
				size="hero"
				align={centered ? 'center' : 'left'}
			/>
			<ActionGroup primary={primary} secondary={secondary} align={!imageRight ? 'center' : 'left'} />
		</div>
		<MediaFigure
			src={imageSrc}
			alt={image.alt || content.headline || ''}
			href={imageHref}
			labelFallback={content.headline || 'View image link'}
			width="hero"
			shape={imageShape}
		/>
	</PageContainer>
</SectionShell>
