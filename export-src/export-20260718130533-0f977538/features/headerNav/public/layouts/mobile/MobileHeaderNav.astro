---
import { HEADER_NAV_RENDER_DEFAULTS } from '../../../core/defaults';
import type { NavItem } from '../../../core/types';

interface Props {
	resolvedSiteName: string;
	resolvedLogoPath?: string;
	showLogo: boolean;
	showSiteNameText: boolean;
	enabledNavItems: NavItem[];
	brandStyle: string;
	logoStyle: string;
	linkStyle: string;
}

const {
	resolvedSiteName,
	resolvedLogoPath,
	showLogo,
	showSiteNameText,
	enabledNavItems,
	brandStyle,
	logoStyle,
	linkStyle,
} = Astro.props as Props;

const mobileBrandGridStyle = `grid-template-columns: ${HEADER_NAV_RENDER_DEFAULTS.mobileLogoColumnWidth} minmax(0, 1fr); column-gap: var(--header-nav-brand-gap);`;
---

<details class="md:hidden">
	<summary
		class="list-none cursor-pointer select-none p-2"
		style="list-style: none;"
	>
		<div class="flex items-center justify-between gap-4">
			<a
				href="/"
				class="min-w-0 grid items-stretch no-underline"
				style={mobileBrandGridStyle}
			>
				{showLogo ? (
					<span class="brand-logo-box flex w-full shrink-0 items-center justify-center self-stretch py-1.5">
						<img
							data-site-brand-logo
							src={resolvedLogoPath}
							alt={resolvedSiteName}
							style={logoStyle}
							class="block h-full w-auto max-w-full object-contain"
							loading="eager"
						/>
					</span>
				) : null}

				{showSiteNameText ? (
					<span class="brand-text-box min-w-0">
						<span data-site-brand-name style={brandStyle}>
							{resolvedSiteName}
						</span>
					</span>
				) : null}
			</a>

			<span class="menu-icon" aria-hidden="true">
				<span></span>
				<span></span>
			</span>
		</div>
	</summary>

	<nav class="w-full pt-2" aria-label="Primary">
		<ul class="flex flex-col gap-2">
			{enabledNavItems.map((item) => (
				<li>
					<a href={item.href} style={linkStyle} class="block w-full py-2">
						{item.label}
					</a>
				</li>
			))}
		</ul>
	</nav>
</details>

<style>
	summary::-webkit-details-marker {
		display: none;
	}

	.menu-icon {
		position: relative;
		display: inline-block;
		width: 24px;
		height: 20px;
		color: currentColor;
	}

	.menu-icon span {
		position: absolute;
		left: 0;
		width: 100%;
		height: 2px;
		background: currentColor;
		transition:
			top 0.25s ease,
			transform 0.25s ease;
	}

	.menu-icon span:nth-child(1) {
		top: 4px;
	}

	.menu-icon span:nth-child(2) {
		top: 14px;
	}

	details[open] .menu-icon span:nth-child(1) {
		top: 9px;
		transform: rotate(45deg);
	}

	details[open] .menu-icon span:nth-child(2) {
		top: 9px;
		transform: rotate(-45deg);
	}
</style>
