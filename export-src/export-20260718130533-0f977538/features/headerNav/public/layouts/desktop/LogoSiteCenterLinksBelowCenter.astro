---
import type { DesktopHeaderLayoutProps } from './types';

type Props = DesktopHeaderLayoutProps;

const {
	resolvedSiteName,
	resolvedLogoPath,
	showLogo,
	showSiteNameText,
	enabledNavItems,
	brandStyle,
	logoStyle,
	navStyle,
	linkListStyle,
	linkStyle,
} = Astro.props as Props;

const linkListClasses = 'flex flex-wrap items-center justify-center';
---

<div
	class="hidden w-full min-w-0 md:flex md:justify-center"
	style="min-height: calc(var(--header-nav-height) + 2.5rem);">
	<div class="flex min-w-0 flex-col items-center justify-center gap-3 py-2">
		<div class="flex min-w-0 items-center justify-center gap-4">
			{showLogo ? (
				<a
					href="/"
					class="brand-logo-box flex shrink-0 items-center justify-center self-stretch py-1.5"
					aria-label={resolvedSiteName}
				>
					<img
						data-site-brand-logo
						src={resolvedLogoPath}
						alt={resolvedSiteName}
						style={logoStyle}
						class="block h-full w-auto object-contain"
						loading="eager"
					/>
				</a>
			) : null}

			{showSiteNameText ? (
				<a href="/" class="min-w-0 no-underline">
					<span data-site-brand-name style={brandStyle}>
						{resolvedSiteName}
					</span>
				</a>
			) : null}
		</div>

		<nav style={navStyle} class="min-w-0" aria-label="Primary">
			<ul style={linkListStyle} class={linkListClasses}>
				{enabledNavItems.map((item) => (
					<li>
						<a href={item.href} style={linkStyle}>
							{item.label}
						</a>
					</li>
				))}
			</ul>
		</nav>
	</div>
</div>
