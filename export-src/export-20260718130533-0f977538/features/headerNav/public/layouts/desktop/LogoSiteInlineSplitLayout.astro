---
import type { DesktopHeaderLayoutProps } from './types';

type Props = DesktopHeaderLayoutProps;

const {
	resolvedSiteName,
	resolvedLogoPath,
	showLogo,
	showSiteNameText,
	enabledNavItems,
	brandStyle,
	logoStyle,
	navStyle,
	linkListStyle,
	linkStyle,
} = Astro.props as Props;

const hasNav = enabledNavItems.length > 0;
const showBrand = showLogo || showSiteNameText;
const inlineSplitLinkListClasses = 'flex items-center whitespace-nowrap';
---

<div
	class="hidden w-full min-w-0 md:grid md:grid-cols-[minmax(0,1fr)_auto] md:items-center md:gap-x-6"
	style="height: var(--header-nav-height);"
>
	<div class="min-w-0 flex items-center">
		{
			showBrand && (
				<a href="/" class="flex min-w-0 items-center gap-3">
					{
						showLogo && (
							<img
								data-site-brand-logo
								src={resolvedLogoPath}
								alt={resolvedSiteName}
								class="block h-auto w-auto max-w-full shrink-0"
								style={logoStyle}
							/>
						)
					}

					{
						showSiteNameText && (
							<span data-site-brand-name class="min-w-0 truncate" style={brandStyle}>
								{resolvedSiteName}
							</span>
						)
					}
				</a>
			)
		}
	</div>

	{
		hasNav && (
			<nav
				class="hidden md:flex md:items-center md:justify-end"
				aria-label="Primary navigation"
				style={navStyle}
			>
				<ul class={inlineSplitLinkListClasses} style={linkListStyle}>
					{enabledNavItems.map((item) => (
						<li>
							<a href={item.href} style={linkStyle}>
								{item.label}
							</a>
						</li>
					))}
				</ul>
			</nav>
		)
	}
</div>
