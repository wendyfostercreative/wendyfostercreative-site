---
import type { DesktopHeaderLayoutProps } from './types';

type Props = DesktopHeaderLayoutProps;

const {
	resolvedSiteName,
	resolvedLogoPath,
	showLogo,
	showSiteNameText,
	enabledNavItems,
	brandStyle,
	logoStyle,
	navStyle,
	linkListStyle,
	linkStyle,
} = Astro.props as Props;

const linkListClasses = 'flex flex-wrap items-center';
---

<div
	class="hidden h-full w-full min-w-0 md:grid md:grid-cols-[7rem_minmax(0,1fr)] md:items-stretch md:gap-x-4"
	style="height: var(--header-nav-height);"
>
	{/* 
		LEFT COLUMN = LOGO LANE
		- This lane fills the full header height.
		- The image is centered inside the lane.
		- Small vertical padding gives breathing room without fake centering hacks.
	*/}
	{showLogo ? (
		<a
			href="/"
			class="flex h-full w-full items-center justify-center self-stretch py-1.5"
			aria-label={resolvedSiteName}
		>
			<img
				data-site-brand-logo
				src={resolvedLogoPath}
				alt={resolvedSiteName}
				style={logoStyle}
				class="block max-h-full w-auto object-contain"
				loading="eager"
			/>
		</a>
	) : (
		/* 
			Keep the left column in place even when there is no logo.
			This preserves the two-column structure.
		*/
		<div class="h-full w-full" />
	)}

	{/*
		RIGHT COLUMN = TITLE + NAV STACK
		- This column also fills the full header height.
		- Its inner content is vertically centered inside the real header height.
		- No py-10 hacks needed.
	*/}
	<div class="min-w-0 flex h-full flex-col justify-center gap-2 py-1.5">
		{showSiteNameText ? (
			<a href="/" class="min-w-0 no-underline">
				<span data-site-brand-name style={brandStyle}>
					{resolvedSiteName}
				</span>
			</a>
		) : null}

		<nav style={navStyle} class="min-w-0" aria-label="Primary">
			<ul style={linkListStyle} class={linkListClasses}>
				{enabledNavItems.map((item) => (
					<li>
						<a href={item.href} style={linkStyle}>
							{item.label}
						</a>
					</li>
				))}
			</ul>
		</nav>
	</div>
</div>
