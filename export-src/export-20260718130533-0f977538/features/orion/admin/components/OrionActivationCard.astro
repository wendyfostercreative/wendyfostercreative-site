---
interface Props {
	messages?: Record<string, string>;
}

const { messages } = Astro.props as Props;

function t(key: string, fallback: string): string {
	return messages?.[key] || fallback;
}
---

<section class="orion-activation" aria-label={t('admin.orion.activation.label', 'Orion Assistant')}>
	<div>
		<div class="orion-activation__eyebrow">{t('admin.orion.activation.eyebrow', 'Guided setup')}</div>
		<h2 class="orion-activation__title">{t('admin.orion.activation.title', 'Orion Assistant')}</h2>
		<p class="orion-activation__body">
			{t('admin.orion.activation.body', 'Orion can guide setup by asking questions, summarizing what it understood, and asking before anything is saved.')}
		</p>
	</div>
	<div class="orion-activation__control">
		<div id="orion-activation-status" class="orion-activation__status">
			{t('admin.orion.activation.status_unknown', 'Checking assistant status')}
		</div>
		<button
			id="orion-activation-toggle"
			class="orion-activation__button"
			type="button"
			data-activate-label={t('admin.orion.activation.activate', 'Activate Orion')}
			data-deactivate-label={t('admin.orion.activation.deactivate', 'Deactivate Orion')}
			data-active-status={t('admin.orion.activation.status_active', 'Assistant is active')}
			data-inactive-status={t('admin.orion.activation.status_inactive', 'Assistant is inactive')}
		>
			{t('admin.orion.activation.activate', 'Activate Orion')}
		</button>
	</div>
</section>

<style>
	.orion-activation {
		align-items: center;
		background: #ffffff;
		border: 1px solid #d8d8d8;
		border-radius: 8px;
		box-shadow: 0 10px 28px rgb(0 0 0 / 6%);
		display: grid;
		gap: 1rem;
		grid-template-columns: minmax(0, 1fr);
		padding: 1rem;
	}

	.orion-activation__eyebrow {
		color: #666666;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.orion-activation__title {
		color: #151515;
		font-size: 1rem;
		font-weight: 800;
		line-height: 1.25;
		margin: 0.125rem 0 0;
	}

	.orion-activation__body {
		color: #666666;
		font-size: 0.875rem;
		line-height: 1.5;
		margin: 0.375rem 0 0;
		max-width: 58rem;
	}

	.orion-activation__control {
		display: grid;
		gap: 0.5rem;
	}

	.orion-activation__status {
		color: #666666;
		font-size: 0.8125rem;
	}

	.orion-activation__button {
		background: #151515;
		border: 1px solid #151515;
		border-radius: 6px;
		color: #ffffff;
		cursor: pointer;
		font: inherit;
		font-size: 0.875rem;
		font-weight: 800;
		padding: 0.625rem 0.875rem;
	}

	.orion-activation__button.is-active {
		background: #ffffff;
		color: #151515;
	}

	@media (min-width: 768px) {
		.orion-activation {
			grid-template-columns: minmax(0, 1fr) auto;
		}

		.orion-activation__control {
			justify-items: end;
			min-width: 12rem;
		}
	}
</style>

<script>
	import { defaultOrionState, loadOrionState, saveOrionState } from '../../core/storage';

	const toggle = document.getElementById('orion-activation-toggle') as HTMLButtonElement | null;
	const status = document.getElementById('orion-activation-status');

	function applyActivationState(): void {
		if (!toggle || !status) return;
		const state = {
			...defaultOrionState(),
			...loadOrionState(),
		};
		const active = Boolean(state.enabled);
		toggle.textContent = active ? toggle.dataset.deactivateLabel || 'Deactivate Orion' : toggle.dataset.activateLabel || 'Activate Orion';
		toggle.classList.toggle('is-active', active);
		status.textContent = active ? toggle.dataset.activeStatus || 'Assistant is active' : toggle.dataset.inactiveStatus || 'Assistant is inactive';
	}

	toggle?.addEventListener('click', () => {
		const state = {
			...defaultOrionState(),
			...loadOrionState(),
		};
		const active = !state.enabled;
		saveOrionState({
			...state,
			enabled: active,
			open: active ? state.open : false,
		});
		applyActivationState();
		window.location.reload();
	});

	applyActivationState();
</script>
