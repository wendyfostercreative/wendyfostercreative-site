---
import { buildOrionAssistantLabels } from '../assistant/shared/context/assistantLabels';
import { getAssistantPageContext } from '../assistant/shared/context/pageContext';

interface Props {
	pathname: string;
	messages?: Record<string, string>;
}

const { pathname, messages } = Astro.props as Props;
const context = getAssistantPageContext(pathname);

function t(key: string, fallback: string): string {
	return messages?.[key] || fallback;
}

const labels = buildOrionAssistantLabels(t);

const resolvedContext = {
	key: context.key,
	step: t(context.stepKey, context.stepFallback),
	title: t(context.titleKey, context.titleFallback),
	goal: t(context.goalKey, context.goalFallback),
	prompt: t(context.promptKey, context.promptFallback),
	allowedActions: context.allowedActions,
};
---

<div
	id="orion-assistant"
	class="orion-assistant"
	data-page-context={JSON.stringify(resolvedContext)}
	data-labels={JSON.stringify(labels)}
	data-pathname={pathname}
>
	<button id="orion-launcher" class="orion-launcher" type="button" aria-expanded="false">
		<span>{labels.launcher}</span>
	</button>

	<section id="orion-panel" class="orion-panel" aria-label="Orion Assistant" hidden>
		<header id="orion-panel-header" class="orion-panel__header">
			<div>
				<div class="orion-panel__eyebrow" data-orion-step>{resolvedContext.step}</div>
				<h2 class="orion-panel__title">{labels.assistantTitle}</h2>
			</div>
			<div class="orion-panel__actions">
				<button id="orion-collapse" class="orion-icon-button" type="button" aria-label={labels.collapseLabel}>_</button>
				<button id="orion-expand" class="orion-icon-button" type="button" aria-label={labels.expandLabel}>[]</button>
				<button id="orion-close" class="orion-icon-button" type="button" aria-label={labels.closeLabel}>x</button>
			</div>
		</header>

		<div class="orion-panel__body">
			<div class="orion-page-card">
				<div class="orion-page-card__title" data-orion-title>{resolvedContext.title}</div>
				<p data-orion-goal>{resolvedContext.goal}</p>
			</div>

			<div id="orion-messages" class="orion-messages" aria-live="polite"></div>
		</div>

		<form id="orion-form" class="orion-composer">
			<label class="orion-composer__label" for="orion-input">{labels.answerLabel}</label>
			<textarea
				id="orion-input"
				class="orion-composer__input"
				rows="4"
				placeholder={labels.placeholder}
			></textarea>
			<div class="orion-composer__actions">
				<button id="orion-clear" class="orion-secondary-button" type="button">{labels.clear}</button>
				<button class="orion-primary-button" type="submit">{labels.continue}</button>
			</div>
		</form>
	</section>
</div>

<style>
	.orion-assistant {
		--orion-bg: #ffffff;
		--orion-text: #151515;
		--orion-muted: #666666;
		--orion-border: #d8d8d8;
		--orion-soft: #f5f5f5;
		--orion-accent: #1f6feb;
		--orion-accent-text: #ffffff;
		color: var(--orion-text);
		font-family: inherit;
		position: fixed;
		z-index: 80;
	}

	.orion-launcher {
		align-items: center;
		background: var(--orion-text);
		border: 1px solid var(--orion-text);
		border-radius: 999px;
		bottom: 1.25rem;
		box-shadow: 0 10px 30px rgb(0 0 0 / 16%);
		color: #ffffff;
		cursor: pointer;
		display: inline-flex;
		font: inherit;
		font-size: 0.875rem;
		font-weight: 700;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		position: fixed;
		right: 1.25rem;
	}

	.orion-panel {
		background: var(--orion-bg);
		border: 1px solid var(--orion-border);
		border-radius: 8px;
		bottom: 1.25rem;
		box-shadow: 0 18px 50px rgb(0 0 0 / 18%);
		display: grid;
		grid-template-rows: auto minmax(0, 1fr) auto;
		height: min(640px, calc(100vh - 2.5rem));
		overflow: hidden;
		position: fixed;
		right: 1.25rem;
		width: min(420px, calc(100vw - 2rem));
	}

	.orion-panel.is-expanded {
		width: min(560px, calc(100vw - 2rem));
	}

	.orion-panel__header {
		align-items: center;
		background: #ffffff;
		border-bottom: 1px solid var(--orion-border);
		cursor: grab;
		display: flex;
		gap: 1rem;
		justify-content: space-between;
		padding: 0.875rem 0.875rem 0.75rem;
		user-select: none;
	}

	.orion-panel__header:active {
		cursor: grabbing;
	}

	.orion-panel__eyebrow {
		color: var(--orion-muted);
		font-size: 0.6875rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.orion-panel__title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.25;
		margin: 0.125rem 0 0;
	}

	.orion-panel__actions {
		align-items: center;
		display: flex;
		gap: 0.375rem;
	}

	.orion-icon-button {
		align-items: center;
		background: var(--orion-soft);
		border: 1px solid var(--orion-border);
		border-radius: 6px;
		color: var(--orion-text);
		cursor: pointer;
		display: inline-flex;
		font: inherit;
		font-size: 0.75rem;
		font-weight: 800;
		height: 2rem;
		justify-content: center;
		line-height: 1;
		width: 2rem;
	}

	.orion-panel__body {
		display: grid;
		gap: 0.75rem;
		grid-template-rows: auto minmax(0, 1fr);
		min-height: 0;
		overflow: hidden;
		padding: 0.875rem;
	}

	.orion-page-card {
		background: var(--orion-soft);
		border: 1px solid var(--orion-border);
		border-radius: 8px;
		padding: 0.75rem;
	}

	.orion-page-card__title {
		font-size: 0.875rem;
		font-weight: 700;
	}

	.orion-page-card p {
		color: var(--orion-muted);
		font-size: 0.8125rem;
		line-height: 1.45;
		margin: 0.25rem 0 0;
	}

	.orion-messages {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
		min-height: 0;
		overflow-y: auto;
		padding-right: 0.25rem;
	}

	:global(.orion-message) {
		border-radius: 8px;
		font-size: 0.875rem;
		line-height: 1.5;
		max-width: 92%;
		padding: 0.625rem 0.75rem;
		white-space: pre-wrap;
	}

	:global(.orion-message--review) {
		max-width: 100%;
		width: 100%;
	}

	:global(.orion-message--handoff) {
		max-width: 100%;
		padding: 0;
		width: 100%;
	}

	:global(.orion-message--assistant) {
		align-self: flex-start;
		background: var(--orion-soft);
		border: 1px solid var(--orion-border);
	}

	:global(.orion-message--assistant.orion-message--handoff) {
		background: transparent;
		border: 0;
	}

	:global(.orion-message--user) {
		align-self: flex-end;
		background: #e8f1ff;
		border: 1px solid #b9d4ff;
	}

	:global(.orion-message__text) {
		margin-bottom: 0.625rem;
	}

	:global(.orion-workflow-handoff) {
		background: linear-gradient(180deg, #f9fafc 0%, #f3f5f8 100%);
		border: 1px solid #d7dee7;
		border-radius: 10px;
		display: grid;
		gap: 0.5rem;
		padding: 0.875rem 0.95rem;
		white-space: normal;
	}

	:global(.orion-workflow-handoff__label) {
		color: var(--orion-muted);
		font-size: 0.75rem;
		font-weight: 800;
		line-height: 1.1;
		text-transform: uppercase;
	}

	:global(.orion-workflow-handoff__headline) {
		font-size: 0.9375rem;
		font-weight: 800;
		line-height: 1.3;
		margin: 0;
	}

	:global(.orion-workflow-handoff__body) {
		color: var(--orion-muted);
		font-size: 0.85rem;
		line-height: 1.45;
		margin: 0;
	}

	:global(.orion-review-card) {
		display: grid;
		gap: 0.875rem;
		white-space: normal;
	}

	:global(.orion-review-card__eyebrow) {
		color: var(--orion-muted);
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	:global(.orion-review-card__title) {
		font-size: 1rem;
		font-weight: 800;
		line-height: 1.25;
		margin: 0;
	}

	:global(.orion-review-card__description-card) {
		background: #ffffff;
		border: 1px solid var(--orion-border);
		border-radius: 10px;
		padding: 0.875rem 1rem;
	}

	:global(.orion-review-card__description) {
		color: var(--orion-muted);
		line-height: 1.45;
		margin: 0;
	}

	:global(.orion-review-card__section) {
		background: #ffffff;
		border: 1px solid var(--orion-border);
		border-radius: 8px;
		display: grid;
		gap: 0.625rem;
		padding: 0.75rem;
	}

	:global(.orion-review-card__section-title) {
		color: var(--orion-muted);
		font-size: 0.75rem;
		font-weight: 800;
		line-height: 1.2;
		margin: 0;
		text-transform: uppercase;
	}

	:global(.orion-review-card__row) {
		display: grid;
		gap: 0.375rem;
	}

	:global(.orion-review-card__label) {
		font-size: 0.8125rem;
		font-weight: 800;
	}

	:global(.orion-review-card__value) {
		color: var(--orion-text);
		line-height: 1.45;
	}

	:global(.orion-review-card__items) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	:global(.orion-review-card__items li) {
		background: var(--orion-soft);
		border: 1px solid var(--orion-border);
		border-radius: 999px;
		font-size: 0.8125rem;
		line-height: 1.2;
		padding: 0.3rem 0.5rem;
	}

	:global(.orion-message-actions) {
		align-self: flex-start;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	:global(.orion-message--review .orion-message-actions) {
		margin-top: 0.875rem;
	}

	:global(.orion-message--handoff .orion-message-actions) {
		margin-top: 0.625rem;
	}

	:global(.orion-message-action) {
		background: #ffffff;
		border: 1px solid var(--orion-border);
		border-radius: 6px;
		color: var(--orion-text);
		cursor: pointer;
		font: inherit;
		font-size: 0.8125rem;
		font-weight: 800;
		padding: 0.625rem 0.875rem;
	}

	:global(.orion-message-action:first-child) {
		background: var(--orion-accent);
		border-color: var(--orion-accent);
		color: var(--orion-accent-text);
	}

	:global(.orion-message--handoff .orion-message-action:first-child) {
		background: #ffffff;
		border-color: var(--orion-border);
		color: var(--orion-text);
	}

	.orion-composer {
		border-top: 1px solid var(--orion-border);
		display: grid;
		gap: 0.5rem;
		padding: 0.875rem;
	}

	.orion-composer__label {
		color: var(--orion-muted);
		font-size: 0.75rem;
		font-weight: 700;
	}

	.orion-composer__input {
		border: 1px solid var(--orion-border);
		border-radius: 8px;
		color: var(--orion-text);
		font: inherit;
		font-size: 0.875rem;
		line-height: 1.45;
		min-height: 6.5rem;
		padding: 0.75rem;
		resize: vertical;
		width: 100%;
	}

	.orion-composer__actions {
		display: flex;
		gap: 0.5rem;
		justify-content: flex-end;
	}

	.orion-primary-button,
	.orion-secondary-button {
		border-radius: 6px;
		cursor: pointer;
		font: inherit;
		font-size: 0.875rem;
		font-weight: 700;
		padding: 0.625rem 0.875rem;
	}

	.orion-primary-button {
		background: var(--orion-accent);
		border: 1px solid var(--orion-accent);
		color: var(--orion-accent-text);
	}

	.orion-secondary-button {
		background: #ffffff;
		border: 1px solid var(--orion-border);
		color: var(--orion-text);
	}

	@media (max-width: 640px) {
		.orion-launcher {
			bottom: 0.75rem;
			right: 0.75rem;
		}

		.orion-panel,
		.orion-panel.is-expanded {
			bottom: 0.75rem;
			height: min(620px, calc(100vh - 1.5rem));
			left: 0.75rem;
			right: 0.75rem;
			width: auto;
		}

		.orion-panel__header {
			cursor: default;
		}
	}
</style>

<script>
	import { initOrionAssistant } from '../assistant/shared/controller';

	const root = document.getElementById('orion-assistant');
	if (root) initOrionAssistant(root);
</script>
