---
import type { NavItem } from '../../../headerNav/core/types';
import type { FooterCustomLink, FooterSettings, FooterSocialLink } from '../../core/types';
import { deriveFooterStyles } from '../styles';

interface Props {
	siteName: string;
	siteNameFont?: string | null;
	logoPath: string;
	navItems: NavItem[];
	footer?: FooterSettings | null;
}

const { siteName, siteNameFont, logoPath, navItems, footer } = Astro.props as Props;

function asNonEmptyString(v: unknown): string | undefined {
	if (typeof v !== 'string') return undefined;
	const s = v.trim();
	return s.length ? s : undefined;
}

function styleString(style: Record<string, string | undefined | null>): string {
	return Object.entries(style)
		.filter(([, v]) => typeof v === 'string' && v.trim().length > 0)
		.map(([k, v]) => `${k}: ${v};`)
		.join(' ');
}

function linkTarget(target: FooterCustomLink['target']): '_self' | '_blank' {
	return target === 'blank' ? '_blank' : '_self';
}

function linkRel(target: FooterCustomLink['target']): string | undefined {
	return target === 'blank' ? 'noreferrer' : undefined;
}

function copyrightText(template: string, resolvedSiteName: string): string {
	const year = String(new Date().getFullYear());
	return template
		.replaceAll('{year}', year)
		.replaceAll('{site_name}', resolvedSiteName);
}

const settings = footer ?? null;
const shouldRender = settings?.enabled !== false;
const styles = deriveFooterStyles(settings);

const resolvedSiteName = asNonEmptyString(siteName) ?? 'My Site';
const resolvedLogoPath = asNonEmptyString(logoPath);
const tagline = asNonEmptyString(settings?.content_json.tagline);
const showLogo = Boolean(settings?.show_logo && resolvedLogoPath);
const showSiteName = Boolean(settings?.show_site_name && resolvedSiteName);
const showBrand = showLogo || showSiteName || Boolean(settings?.show_tagline && tagline);

const pageLinks = settings?.show_page_links
	? navItems.filter((item) => item.enabled)
	: [];
const customLinks = settings?.show_custom_links
	? settings.content_json.custom_links.filter((link) => asNonEmptyString(link.href) && asNonEmptyString(link.label))
	: [];
const socialLinks: FooterSocialLink[] = settings?.show_social_links
	? settings.content_json.social_links.filter((link) => asNonEmptyString(link.href) && asNonEmptyString(link.label))
	: [];

const showLinks = pageLinks.length > 0 || customLinks.length > 0;
const copyright = settings?.content_json.copyright;
const showCopyright = Boolean(
	settings?.show_copyright &&
	copyright &&
	copyright.mode !== 'hidden' &&
	asNonEmptyString(copyright.text),
);

const footerStyle = styleString(styles.footerStyle);
const containerStyle = styleString(styles.containerStyle);
const brandStyle = styleString({
	...styles.brandStyle,
	'font-family': 'var(--site-font-siteName)',
});
const logoStyle = styleString(styles.logoStyle);
const linkStyle = styleString(styles.linkStyle);
const textDirection = settings?.text_direction === 'rtl' ? 'rtl' : 'ltr';
const brandLayout = settings?.brand_layout === 'inline' ? 'inline' : 'stacked';
---

{shouldRender ? (
	<footer dir={textDirection} style={footerStyle} class="w-full bg-[var(--site-color-bg)] text-[var(--site-color-text)]">
		<div style={containerStyle} class="mx-auto grid w-full gap-8">
			<div class="grid gap-8 md:grid-cols-[minmax(0,1fr)_minmax(16rem,auto)] md:items-start">
				{showBrand ? (
					<div class="grid max-w-xl gap-3">
						<div class:list={[
							'flex gap-3',
							brandLayout === 'inline' ? 'items-center' : 'flex-col items-start',
						]}>
							{showLogo ? (
								<img data-site-brand-logo src={resolvedLogoPath} alt={resolvedSiteName} style={logoStyle} class="block" loading="lazy" />
							) : null}
							{showSiteName ? (
								<div data-site-brand-name style={brandStyle} class="text-base font-semibold leading-tight">
									{resolvedSiteName}
								</div>
							) : null}
						</div>

						{settings?.show_tagline && tagline ? (
							<p class="max-w-prose text-sm leading-6 text-[var(--site-color-text-muted)]">
								{tagline}
							</p>
						) : null}
					</div>
				) : <div></div>}

				{showLinks ? (
					<nav aria-label="Footer" class="grid gap-4 sm:grid-cols-2">
						{pageLinks.length > 0 ? (
							<div class="grid gap-2">
								<ul class:list={[
									'grid gap-2 text-sm',
									settings?.link_layout === 'inline' ? 'sm:flex sm:flex-wrap sm:gap-x-4' : '',
								]}>
									{pageLinks.map((item) => (
										<li>
											<a href={item.href} style={linkStyle} class="text-[var(--site-color-text)] hover:text-[var(--site-color-link-hover)]">
												{item.label}
											</a>
										</li>
									))}
								</ul>
							</div>
						) : null}

						{customLinks.length > 0 ? (
							<div class="grid gap-2">
								<ul class:list={[
									'grid gap-2 text-sm',
									settings?.link_layout === 'inline' ? 'sm:flex sm:flex-wrap sm:gap-x-4' : '',
								]}>
									{customLinks.map((link) => (
										<li>
											<a
												href={link.href}
												target={linkTarget(link.target)}
												rel={linkRel(link.target)}
												style={linkStyle}
												class="text-[var(--site-color-text)] hover:text-[var(--site-color-link-hover)]"
											>
												{link.label}
											</a>
										</li>
									))}
								</ul>
							</div>
						) : null}
					</nav>
				) : null}
			</div>

			{socialLinks.length > 0 || showCopyright ? (
				<div class="flex flex-col gap-4 border-t border-[var(--site-color-border-soft)] pt-5 text-sm text-[var(--site-color-text-muted)] md:flex-row md:items-center md:justify-between">
					{socialLinks.length > 0 ? (
						<ul class="flex flex-wrap gap-x-4 gap-y-2">
							{socialLinks.map((link) => (
								<li>
									<a href={link.href} target="_blank" rel="noreferrer" style={linkStyle} class="text-[var(--site-color-text)] hover:text-[var(--site-color-link-hover)]">
										{link.label}
									</a>
								</li>
							))}
						</ul>
					) : <div></div>}

					{showCopyright && copyright ? (
						<p>{copyrightText(copyright.text, resolvedSiteName)}</p>
					) : null}
				</div>
			) : null}
		</div>
	</footer>
) : null}
