---
import AdminSection from '../../../../components/admin/layout/Section.astro';
import AdminField from '../../../../components/admin/fields/Field.astro';
import AdminSelect from '../../../../components/admin/fields/Select.astro';
import AdminTextarea from '../../../../components/admin/fields/Textarea.astro';

import type { FooterSettings } from '../../core/types';
import {
	booleanOptions,
	linkLayoutOptions,
} from '../forms/footerFields';

type Props = {
	footer: FooterSettings;
	t: (key: string, fallback: string) => string;
};

const { footer, t } = Astro.props;
function optionLabel(group: string, value: string, fallback: string): string {
	return t(`admin.footer.options.${group}.${value}`, fallback);
}

const customLinksJson = JSON.stringify(footer.content_json.custom_links, null, 2);
---
<AdminSection title={t('admin.footer.links.title', 'Links')} description={t('admin.footer.links.description', 'Page links are derived from published pages. Custom links are owner-authored footer content.')}>
	<div class="grid gap-5">
		<div class="grid gap-4 sm:grid-cols-3">
			<AdminField label={t('admin.footer.links.show_page_links', 'Show page links')} forId="show_page_links">
				<AdminSelect id="show_page_links" name="show_page_links" density="compact">
					{booleanOptions.map((option) => (
						<option value={option.value} selected={String(footer.show_page_links) === option.value}>
							{optionLabel('boolean', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>

			<AdminField label={t('admin.footer.links.show_custom_links', 'Show custom links')} forId="show_custom_links">
				<AdminSelect id="show_custom_links" name="show_custom_links" density="compact">
					{booleanOptions.map((option) => (
						<option value={option.value} selected={String(footer.show_custom_links) === option.value}>
							{optionLabel('boolean', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>

			<AdminField label={t('admin.footer.links.link_layout', 'Link layout')} forId="link_layout">
				<AdminSelect id="link_layout" name="link_layout" density="compact">
					{linkLayoutOptions.map((option) => (
						<option value={option.value} selected={footer.link_layout === option.value}>
							{optionLabel('link_layout', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>
		</div>

		<AdminField label={t('admin.footer.links.custom_links_json', 'Custom links JSON')} forId="custom_links_json" help={t('admin.footer.links.custom_links_help', 'Array of { id, label, href, target }. Public copy stays exactly as written.')}>
			<AdminTextarea id="custom_links_json" name="custom_links_json" rows={8} value={customLinksJson} class="font-mono" />
		</AdminField>
	</div>
</AdminSection>
