---
import AdminSection from '../../../../components/admin/layout/Section.astro';
import AdminField from '../../../../components/admin/fields/Field.astro';
import AdminSelect from '../../../../components/admin/fields/Select.astro';
import AdminColorField from '../../../../components/admin/fields/ColorField.astro';

import type { FooterSettings } from '../../core/types';
import {
	booleanOptions,
	contentWidthOptions,
	layoutPresetOptions,
	textDirectionOptions,
} from '../forms/footerFields';

type Props = {
	footer: FooterSettings;
	t: (key: string, fallback: string) => string;
};

const { footer, t } = Astro.props;
function optionLabel(group: string, value: string, fallback: string): string {
	return t(`admin.footer.options.${group}.${value}`, fallback);
}
---
<AdminSection title={t('admin.footer.layout.title', 'Layout')} description={t('admin.footer.layout.description', 'Controls whether the footer appears, its layout preset, width, direction, and base colors.')}>
	<div class="grid gap-5">
		<div class="grid gap-4 sm:grid-cols-2">
			<AdminField label={t('admin.footer.layout.enabled', 'Footer enabled')} forId="enabled">
				<AdminSelect id="enabled" name="enabled" density="compact">
					{booleanOptions.map((option) => (
						<option value={option.value} selected={String(footer.enabled) === option.value}>
							{optionLabel('boolean', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>

			<AdminField label={t('admin.footer.layout.layout_preset', 'Layout preset')} forId="layout_preset">
				<AdminSelect id="layout_preset" name="layout_preset" density="compact">
					{layoutPresetOptions.map((option) => (
						<option value={option.value} selected={footer.layout_preset === option.value}>
							{optionLabel('layout_preset', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>

			<AdminField label={t('admin.footer.layout.content_width', 'Content width')} forId="content_width">
				<AdminSelect id="content_width" name="content_width" density="compact">
					{contentWidthOptions.map((option) => (
						<option value={option.value} selected={footer.content_width === option.value}>
							{optionLabel('content_width', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>

			<AdminField label={t('admin.footer.layout.text_direction', 'Text direction')} forId="text_direction">
				<AdminSelect id="text_direction" name="text_direction" density="compact">
					{textDirectionOptions.map((option) => (
						<option value={option.value} selected={footer.text_direction === option.value}>
							{optionLabel('text_direction', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>
		</div>

		<div class="grid gap-4 sm:grid-cols-2">
			<AdminColorField label={t('admin.footer.layout.background_color', 'Background color')} id="background_color" name="background_color" value={footer.background_color ?? ''} />
			<AdminColorField label={t('admin.footer.layout.text_color', 'Text color')} id="text_color" name="text_color" value={footer.text_color ?? ''} />
		</div>
	</div>
</AdminSection>
