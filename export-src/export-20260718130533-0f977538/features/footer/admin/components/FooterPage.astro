---
import AdminCard from '../../../../components/admin/cards/Card.astro';
import Button from '../../../../components/ui/Button.astro';

import type { FooterSettings } from '../../core/types';
import FooterLayoutSection from './FooterLayoutSection.astro';
import FooterBrandSection from './FooterBrandSection.astro';
import FooterLinksSection from './FooterLinksSection.astro';
import FooterContentSection from './FooterContentSection.astro';
import FooterBorderSection from './FooterBorderSection.astro';

type Props = {
	footer: FooterSettings;
	t: (key: string, fallback: string) => string;
};

const { footer, t } = Astro.props;
---

<form id="footer_form" class="grid gap-6" method="POST" action="/admin/action/footer/save">
	<AdminCard>
		<FooterLayoutSection footer={footer} t={t} />
	</AdminCard>

	<AdminCard>
		<FooterBrandSection footer={footer} t={t} />
	</AdminCard>

	<AdminCard>
		<FooterLinksSection footer={footer} t={t} />
	</AdminCard>

	<AdminCard>
		<FooterContentSection footer={footer} t={t} />
	</AdminCard>

	<AdminCard>
		<FooterBorderSection footer={footer} t={t} />
	</AdminCard>

	<AdminCard>
		<div class="flex items-center gap-3">
			<Button type="submit">
				{t('admin.footer.actions.save', 'Save footer settings')}
			</Button>
			<span id="status" class="text-sm text-[var(--site-color-text-muted)]"></span>
		</div>
	</AdminCard>
</form>
