---
import AdminSection from '../../../../components/admin/layout/Section.astro';
import AdminField from '../../../../components/admin/fields/Field.astro';
import AdminInput from '../../../../components/admin/fields/Input.astro';
import AdminSelect from '../../../../components/admin/fields/Select.astro';
import AdminTextarea from '../../../../components/admin/fields/Textarea.astro';

import type { FooterSettings } from '../../core/types';
import { booleanOptions } from '../forms/footerFields';

type Props = {
	footer: FooterSettings;
	t: (key: string, fallback: string) => string;
};

const { footer, t } = Astro.props;
function optionLabel(group: string, value: string, fallback: string): string {
	return t(`admin.footer.options.${group}.${value}`, fallback);
}

const socialLinksJson = JSON.stringify(footer.content_json.social_links, null, 2);
---
<AdminSection title={t('admin.footer.content.title', 'Public Content')} description={t('admin.footer.content.description', 'Owner-authored footer copy and social links. JSON keys and option values stay English.')}>
	<div class="grid gap-5">
		<div class="grid gap-4 sm:grid-cols-3">
			<AdminField label={t('admin.footer.content.show_tagline', 'Show tagline')} forId="show_tagline">
				<AdminSelect id="show_tagline" name="show_tagline" density="compact">
					{booleanOptions.map((option) => (
						<option value={option.value} selected={String(footer.show_tagline) === option.value}>
							{optionLabel('boolean', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>

			<AdminField label={t('admin.footer.content.show_social_links', 'Show social links')} forId="show_social_links">
				<AdminSelect id="show_social_links" name="show_social_links" density="compact">
					{booleanOptions.map((option) => (
						<option value={option.value} selected={String(footer.show_social_links) === option.value}>
							{optionLabel('boolean', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>

			<AdminField label={t('admin.footer.content.show_copyright', 'Show copyright')} forId="show_copyright">
				<AdminSelect id="show_copyright" name="show_copyright" density="compact">
					{booleanOptions.map((option) => (
						<option value={option.value} selected={String(footer.show_copyright) === option.value}>
							{optionLabel('boolean', option.value, option.label)}
						</option>
					))}
				</AdminSelect>
			</AdminField>
		</div>

		<AdminField label={t('admin.footer.content.tagline', 'Tagline')} forId="tagline">
			<AdminInput id="tagline" name="tagline" value={footer.content_json.tagline} />
		</AdminField>

		<AdminField label={t('admin.footer.content.social_links_json', 'Social links JSON')} forId="social_links_json" help={t('admin.footer.content.social_links_help', 'Array of { id, platform, label, href }. Public labels stay exactly as written.')}>
			<AdminTextarea id="social_links_json" name="social_links_json" rows={8} value={socialLinksJson} class="font-mono" />
		</AdminField>

		<div class="grid gap-4 sm:grid-cols-[14rem_1fr]">
			<AdminField label={t('admin.footer.content.copyright_mode', 'Copyright mode')} forId="copyright_mode">
				<AdminSelect id="copyright_mode" name="copyright_mode" density="compact">
					{['generated', 'custom', 'hidden'].map((value) => (
						<option value={value} selected={footer.content_json.copyright.mode === value}>
							{optionLabel('copyright_mode', value, value)}
						</option>
					))}
				</AdminSelect>
			</AdminField>

			<AdminField label={t('admin.footer.content.copyright_text', 'Copyright text')} forId="copyright_text">
				<AdminInput id="copyright_text" name="copyright_text" value={footer.content_json.copyright.text} />
			</AdminField>
		</div>
	</div>
</AdminSection>
