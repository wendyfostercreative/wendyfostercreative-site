---
import AdminSection from '../../../../components/admin/layout/Section.astro';
import AdminField from '../../../../components/admin/fields/Field.astro';
import AdminInput from '../../../../components/admin/fields/Input.astro';
import AdminTextarea from '../../../../components/admin/fields/Textarea.astro';

import type { SiteConfig } from '../../core/types';

type Props = {
	site: SiteConfig;
	t: (key: string, fallback: string) => string;
};

const { site, t } = Astro.props;
---

<AdminSection title={t('admin.site_config.seo.title', 'SEO defaults')} description={t('admin.site_config.seo.description', 'Used when a page does not define its own SEO metadata.')}>
	<AdminField
		label={t('admin.site_config.seo.default_title', 'Default SEO title (optional)')}
		forId="default_seo_title"
		help={t('admin.site_config.seo.default_title_help', 'Used when a page does not define its own SEO title.')}
	>
		<AdminInput id="default_seo_title" name="default_seo_title" value={site.seo_defaults.title ?? ''} />
	</AdminField>

	<AdminField
		label={t('admin.site_config.seo.default_description', 'Default SEO description (optional)')}
		forId="default_seo_description"
		help={t('admin.site_config.seo.default_description_help', 'Used when a page does not define its own SEO description.')}
	>
		<AdminTextarea
			id="default_seo_description"
			name="default_seo_description"
			rows={4}
			value={site.seo_defaults.description ?? ''}
		/>
	</AdminField>
</AdminSection>
