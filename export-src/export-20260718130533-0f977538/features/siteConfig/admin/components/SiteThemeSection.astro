---
import AdminSection from '../../../../components/admin/layout/Section.astro';
import AdminColorField from '../../../../components/admin/fields/ColorField.astro';
import Button from '../../../../components/ui/Button.astro';

import type { SiteThemeColorKey } from '../forms/themeFields';

type ThemeField<Key extends string> = {
	key: Key;
	label: string;
	name: string;
	id: string;
	value: string;
	section: 'header' | 'main' | 'footer';
};

type Props = {
	colorFields: Array<ThemeField<SiteThemeColorKey>>;
	t: (key: string, fallback: string) => string;
};

const { colorFields, t } = Astro.props;
const sections: Array<{
	key: 'header' | 'main' | 'footer';
	title: string;
	description: string;
	fields: Array<ThemeField<SiteThemeColorKey>>;
}> = [
	{
		key: 'header',
		title: t('admin.site_config.theme.section.header_title', 'Header Theme'),
		description: t('admin.site_config.theme.section.header_description', 'Controls the header surface, text, and border defaults inherited by the header navigation.'),
		fields: colorFields.filter((field) => field.section === 'header'),
	},
	{
		key: 'main',
		title: t('admin.site_config.theme.section.main_title', 'Main Site Theme'),
		description: t('admin.site_config.theme.section.main_description', 'Controls the main page surfaces, shared text colors, borders, and button styling used across the site.'),
		fields: colorFields.filter((field) => field.section === 'main'),
	},
	{
		key: 'footer',
		title: t('admin.site_config.theme.section.footer_title', 'Footer Theme'),
		description: t('admin.site_config.theme.section.footer_description', 'Controls the footer surface, text, and border defaults inherited by the footer.'),
		fields: colorFields.filter((field) => field.section === 'footer'),
	},
];
---

<AdminSection
	title={t('admin.site_config.theme.title', 'Theme')}
	description={t('admin.site_config.theme.description', 'Set the site color palette used across backgrounds, text, borders, and buttons.')}
>
	<div class="grid gap-6">
		{sections.map((section) => (
			<div class="grid gap-3 rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-bg)] p-4">
				<div>
					<h3 class="text-sm font-semibold text-[var(--site-color-text)]">{section.title}</h3>
					<p class="mt-1 text-sm text-[var(--site-color-text-muted)]">{section.description}</p>
				</div>

				<div class="grid gap-4 sm:grid-cols-2">
					{section.fields.map((field) => (
						<AdminColorField
							label={field.label}
							id={field.id}
							name={field.name}
							value={field.value}
						/>
					))}
				</div>
			</div>
		))}

		<div class="grid gap-2">
			<p class="text-sm text-[var(--site-color-text-muted)]">
				Review the card. If it looks right, click APPLY to continue to Components.
			</p>
			<div class="site-config-theme-apply flex items-center gap-3">
				<Button type="button">APPLY</Button>
			</div>
		</div>
	</div>
</AdminSection>
