---
import AdminCard from '../../../../components/admin/cards/Card.astro';
import AdminSummaryPanel from '../../../../components/admin/cards/SummaryPanel.astro';
import Button from '../../../../components/ui/Button.astro';

import type { SiteConfig } from '../../core/types';
import { resolveSiteTheme } from '../../core/theme';
import SiteBrandingSection from './SiteBrandingSection.astro';
import SiteTypographySection from './SiteTypographySection.astro';
import SiteThemeSection from './SiteThemeSection.astro';
import SiteComponentsSection from './SiteComponentsSection.astro';
import SiteSeoSection from './SiteSeoSection.astro';
import {
	getSiteThemeColorFields,
	getSiteThemeLayoutFields,
	getSiteThemeRadiusFields,
} from '../forms/themeFields';

type SummaryItem = {
	key?: string;
	label: string;
	value: string;
};

type Props = {
	site: SiteConfig;
	summaryItems: SummaryItem[];
	t: (key: string, fallback: string) => string;
};

const { site, summaryItems, t } = Astro.props;
const resolvedTheme = resolveSiteTheme(site.theme);
const colorFields = getSiteThemeColorFields(resolvedTheme).map((field) => ({
	...field,
	label: t(`admin.site_config.theme.color.${field.key}`, field.label),
}));
const layoutFields = getSiteThemeLayoutFields(resolvedTheme).map((field) => ({
	...field,
	label: t(`admin.site_config.components.layout.${field.key}`, field.label),
}));
const radiusFields = getSiteThemeRadiusFields(resolvedTheme).map((field) => ({
	...field,
	label: t(`admin.site_config.components.radius.${field.key}`, field.label),
}));
---

<div
	class="grid gap-6"
	data-site-config-display-root
	data-saved-site={JSON.stringify(site)}
	data-saved-status={t('admin.site_config.saved_status', '')}
	data-preview-status={t('admin.site_config.preview_status', 'Preview from Orion. Review the suggested changes in the page before applying them.')}
	data-staged-status={t('admin.site_config.staged_status', 'Draft from Orion is loaded here. Changes are not saved until you use the SAVE SETTINGS button.')}
>
	<AdminCard>
		<div class="grid gap-3">
			<p class="text-sm text-[var(--site-color-text)]" data-site-config-display-status hidden></p>
			<p class="max-w-prose text-sm leading-6 text-[var(--site-color-text-muted)]">
				{t('admin.site_config.manual_body', 'The manual controls below are a fallback for direct edits. Orion Step 02 remains the primary guided flow for staged identity and theme setup.')}
			</p>
		</div>
	</AdminCard>

	<AdminSummaryPanel items={summaryItems} />

	<form id="site_form" class="grid gap-6" method="POST" action="/admin/action/site/save">
		<AdminCard class="site-config-branding-card">
			<SiteBrandingSection site={site} t={t} />
		</AdminCard>

		<AdminCard class="site-config-typography-card">
			<SiteTypographySection site={site} t={t} />
		</AdminCard>

		<AdminCard class="site-config-theme-card">
			<SiteThemeSection colorFields={colorFields} t={t} />
		</AdminCard>

		<AdminCard class="site-config-components-card">
			<SiteComponentsSection layoutFields={layoutFields} radiusFields={radiusFields} t={t} />
		</AdminCard>

		<AdminCard class="site-config-seo-card">
			<SiteSeoSection site={site} t={t} />
		</AdminCard>

		<AdminCard>
			<div class="flex items-center gap-3">
				<Button type="submit">
					{t('admin.site_config.actions.save', 'Save identity & theme')}
				</Button>
				<span id="status" class="text-sm text-[var(--site-color-text-muted)]"></span>
			</div>
		</AdminCard>
	</form>
</div>

<script>
	import { initDisplayController } from '../controllers/displayController';

	const root = document.querySelector('[data-site-config-display-root]') as HTMLElement | null;
	if (root) initDisplayController(root);
</script>
