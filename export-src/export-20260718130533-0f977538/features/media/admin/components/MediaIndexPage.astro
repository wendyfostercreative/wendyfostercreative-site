---
import AdminPageHeader from '../../../../components/admin/layout/PageHeader.astro';
import AdminPageShell from '../../../../components/admin/layout/PageShell.astro';
import AdminCard from '../../../../components/admin/cards/Card.astro';
import AdminSection from '../../../../components/admin/layout/Section.astro';
import MediaTypeCard from './MediaTypeCard.astro';

type Props = {
	t: (key: string, fallback: string) => string;
};

const { t } = Astro.props;
---

<AdminPageShell width="content">
	<AdminPageHeader
		title={t('admin.media.index.header.title', 'Admin: Media')}
		backHref="/admin"
		backLabel={t('admin.media.index.header.back', 'Back')}
		description={t('admin.media.index.header.description', 'Choose which kind of media inventory to manage.')}
	/>

	<AdminCard>
		<AdminSection title={t('admin.media.index.types.title', 'Media Types')} description={t('admin.media.index.types.description', 'Each media type can own its upload, edit, and public display workflow.')}>
			<div class="grid gap-4 md:grid-cols-2">
				<MediaTypeCard
					title={t('admin.media.index.images.title', 'Images')}
					description={t('admin.media.index.images.description', 'Upload and manage gallery, content, and hero images.')}
					href="/admin/media/images"
					status={t('admin.media.index.status.active', 'Active')}
				/>
				<MediaTypeCard
					title={t('admin.media.index.videos.title', 'Videos')}
					description={t('admin.media.index.videos.description', 'Video media management can be added here later.')}
					href="#"
					status={t('admin.media.index.status.later', 'Later')}
				/>
				<MediaTypeCard
					title={t('admin.media.index.documents.title', 'Documents')}
					description={t('admin.media.index.documents.description', 'PDFs, downloads, and other documents can be added here later.')}
					href="#"
					status={t('admin.media.index.status.later', 'Later')}
				/>
			</div>
		</AdminSection>
	</AdminCard>
</AdminPageShell>
