---
import type { AdminMediaImageItem } from '../../../core/types';

type Props = {
	fieldName: string;
	fieldValue: string;
	images?: AdminMediaImageItem[];
	t?: (key: string, fallback: string) => string;
	sectionImageField?: string;
	mediaRole?: string;
	uploadCollection?: string;
	uploadCategory?: string;
	thumbFieldName?: string;
	thumbFieldValue?: string;
};

const { fieldName, fieldValue, t = (_key: string, fallback: string) => fallback, sectionImageField, mediaRole = '', uploadCollection = '', uploadCategory = '', thumbFieldName, thumbFieldValue = '' } = Astro.props;
---

<div
	class="grid gap-3"
	data-image-path-picker
	data-image-picker-loading={t('admin.media.image_picker.loading', 'Loading...')}
	data-image-picker-failed-to-load={t('admin.media.image_picker.failed_to_load', 'Failed to load')}
	data-image-picker-uploading={t('admin.media.image_picker.uploading', 'Uploading...')}
	data-image-picker-upload-failed={t('admin.media.image_picker.upload_failed', 'Upload failed')}
	data-image-media-role={mediaRole}
	data-image-upload-collection={uploadCollection}
	data-image-upload-category={uploadCategory}
>
	<div class="grid gap-3 sm:grid-cols-[180px_1fr] sm:items-start">
		<div
			class="overflow-hidden rounded-[var(--site-radius-input)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-panel)]"
			style="aspect-ratio: 1 / 1;"
			data-image-preview-wrap
		>
			<img class="h-full w-full object-cover hidden" alt={t('admin.media.image_picker.selected_alt', 'Selected image')} loading="lazy" data-image-preview />
			<div
				class="h-full w-full flex items-center justify-center text-xs text-[var(--site-color-text-muted)]"
				data-image-preview-empty
			>
				{t('admin.media.image_picker.no_image', 'No image selected')}
			</div>
		</div>

		<div class="grid gap-2">
			<input type="hidden" name={fieldName} value={fieldValue} data-image-path-input data-section-image data-section-image-field={sectionImageField} />
			{thumbFieldName ? <input type="hidden" name={thumbFieldName} value={thumbFieldValue} data-image-thumb-path-input /> : null}

			<div class="flex flex-wrap items-center gap-2">
				<input
					class="hidden"
					type="file"
					accept="image/jpeg,image/png,image/webp"
					data-image-file-input
				/>
				<button
					class="rounded-[var(--site-radius-button)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-button-bg)] px-3 py-2 text-sm text-[var(--site-color-button-text)]"
					type="button"
					data-image-upload
				>
					{t('admin.media.image_picker.upload', 'Upload image')}
				</button>
				<button
					class="rounded-[var(--site-radius-button)] border border-[var(--site-color-border-soft)] bg-white px-3 py-2 text-sm text-[var(--site-color-text)]"
					type="button"
					data-image-choose
				>
					{t('admin.media.image_picker.choose_existing', 'Choose existing')}
				</button>
				<button
					class="rounded-[var(--site-radius-button)] border border-[var(--site-color-border-soft)] bg-white px-3 py-2 text-sm text-[var(--site-color-text)]"
					type="button"
					data-image-clear
				>
					{t('admin.media.image_picker.clear', 'Clear')}
				</button>
				<div class="text-xs text-[var(--site-color-text-muted)]" data-image-status></div>
			</div>
		</div>
	</div>

	<div class="hidden" data-image-library>
		<div
			class="mt-2 flex flex-col gap-3 overflow-hidden rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-white p-3"
		>
			<div class="flex items-center justify-between gap-2">
				<div class="text-sm font-medium text-[var(--site-color-text)]">{t('admin.media.image_picker.library_title', 'Content media')}</div>
				<button
					class="rounded-[var(--site-radius-button)] border border-[var(--site-color-border-soft)] bg-white px-2 py-1 text-xs text-[var(--site-color-text)]"
					type="button"
					data-image-library-close
				>
					{t('admin.media.image_picker.close', 'Close')}
				</button>
			</div>
			<div
				class="grid max-h-[32rem] gap-3 overflow-y-auto pb-1 pr-1 sm:grid-cols-2 lg:grid-cols-3"
				data-image-library-grid
			></div>
		</div>
	</div>
</div>

<script>
	import {
		listAdminContentMedia,
		uploadAdminContentMedia,
	} from '../../../admin/api';
	import { resolvePreviewSrc } from '../../core/paths';
	import type { AdminContentMediaListItem, AdminContentMediaUploadResponse } from '../../../core/types';

	function setStatus(root: HTMLElement, message: string): void {
		const status = root.querySelector('[data-image-status]') as HTMLElement | null;
		if (status) status.textContent = message;
	}

	function setValue(root: HTMLElement, value: string, thumbValue = ''): void {
		const input = root.querySelector('[data-image-path-input]') as HTMLInputElement | null;
		const thumbInput = root.querySelector('[data-image-thumb-path-input]') as HTMLInputElement | null;
		if (!input) return;
		input.value = value;
		if (thumbInput) thumbInput.value = thumbValue;
		input.dispatchEvent(new Event('input', { bubbles: true }));
		thumbInput?.dispatchEvent(new Event('input', { bubbles: true }));
	}

	function syncPreview(root: HTMLElement): void {
		const input = root.querySelector('[data-image-path-input]') as HTMLInputElement | null;
		const img = root.querySelector('[data-image-preview]') as HTMLImageElement | null;
		const empty = root.querySelector('[data-image-preview-empty]') as HTMLElement | null;
		if (!input || !img || !empty) return;
		const thumbInput = root.querySelector('[data-image-thumb-path-input]') as HTMLInputElement | null;
		const src = resolvePreviewSrc(thumbInput?.value || input.value);
		if (src) {
			img.src = src;
			img.classList.remove('hidden');
			empty.classList.add('hidden');
		} else {
			img.removeAttribute('src');
			img.classList.add('hidden');
			empty.classList.remove('hidden');
		}
	}

	async function fetchLibrary(): Promise<AdminContentMediaListItem[]> {
		return await listAdminContentMedia({ limit: 24, offset: 0 });
	}

	function buildLibraryButton(root: HTMLElement, item: AdminContentMediaListItem): HTMLButtonElement {
		const button = document.createElement('button');
		button.type = 'button';
		button.className =
			'flex h-full min-h-0 flex-col gap-2 overflow-hidden rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-white p-3 text-left text-[var(--site-color-text)] transition hover:border-[var(--site-color-border)]';
		button.addEventListener('click', () => {
			setValue(root, item.webp_path, item.thumb_path || '');
			syncPreview(root);
			const panel = root.querySelector('[data-image-library]') as HTMLElement | null;
			if (panel) panel.classList.add('hidden');
		});

		const previewWrap = document.createElement('div');
		previewWrap.className =
			'flex w-full shrink-0 items-center justify-center overflow-hidden rounded-[var(--site-radius-input)] bg-[var(--site-color-panel)]';
		previewWrap.style.aspectRatio = '1 / 1';
		const img = document.createElement('img');
		img.src = resolvePreviewSrc(item.thumb_path || item.webp_path);
		img.alt = item.title || item.file_key;
		img.loading = 'lazy';
		img.className = 'block h-full w-full object-contain';
		previewWrap.appendChild(img);

		const label = document.createElement('div');
		label.className = 'text-sm font-medium text-[var(--site-color-text)]';
		label.textContent = item.title || item.file_key;

		button.appendChild(previewWrap);
		button.appendChild(label);
		return button;
	}

	function renderLibrary(root: HTMLElement, items: AdminContentMediaListItem[]): void {
		const grid = root.querySelector('[data-image-library-grid]') as HTMLElement | null;
		if (!grid) return;
		grid.innerHTML = '';
		items.forEach((item) => {
			grid.appendChild(buildLibraryButton(root, item));
		});
	}

	async function uploadFile(root: HTMLElement, file: File): Promise<AdminContentMediaUploadResponse> {
		const mediaRole = root.dataset.imageMediaRole?.trim();
		const collection = root.dataset.imageUploadCollection?.trim();
		const category = root.dataset.imageUploadCategory?.trim();
		return await uploadAdminContentMedia(file, {
			title: file.name.replace(/\.[^.]+$/, ''),
			media_role: mediaRole || undefined,
			collection: collection || undefined,
			category: category || undefined,
		});
	}

	function initImagePathPickers(root: ParentNode | null = document): void {
		const scope = root ?? document;
		Array.from(scope.querySelectorAll?.('[data-image-path-picker]') ?? []).forEach((node) => {
			const pickerRoot = node as HTMLElement;
			if (pickerRoot.dataset.imagePathPickerInitialized === 'true') return;
			pickerRoot.dataset.imagePathPickerInitialized = 'true';

			const input = pickerRoot.querySelector('[data-image-path-input]') as HTMLInputElement | null;
			const clearBtn = pickerRoot.querySelector('[data-image-clear]') as HTMLButtonElement | null;
			const chooseBtn = pickerRoot.querySelector('[data-image-choose]') as HTMLButtonElement | null;
			const uploadBtn = pickerRoot.querySelector('[data-image-upload]') as HTMLButtonElement | null;
			const fileInput = pickerRoot.querySelector('[data-image-file-input]') as HTMLInputElement | null;
			const panel = pickerRoot.querySelector('[data-image-library]') as HTMLElement | null;
			const closeBtn = pickerRoot.querySelector('[data-image-library-close]') as HTMLButtonElement | null;
			const loadingMessage = pickerRoot.dataset.imagePickerLoading || 'Loading...';
			const failedToLoadMessage = pickerRoot.dataset.imagePickerFailedToLoad || 'Failed to load';
			const uploadingMessage = pickerRoot.dataset.imagePickerUploading || 'Uploading...';
			const uploadFailedMessage = pickerRoot.dataset.imagePickerUploadFailed || 'Upload failed';

			syncPreview(pickerRoot);
			input?.addEventListener('input', () => syncPreview(pickerRoot));

			clearBtn?.addEventListener('click', () => {
				setValue(pickerRoot, '', '');
				syncPreview(pickerRoot);
			});

			chooseBtn?.addEventListener('click', async () => {
				if (!panel) return;
				panel.classList.remove('hidden');
				setStatus(pickerRoot, loadingMessage);
				try {
					const items = await fetchLibrary();
					renderLibrary(pickerRoot, items);
					setStatus(pickerRoot, '');
				} catch (err) {
					setStatus(pickerRoot, err instanceof Error ? err.message : failedToLoadMessage);
				}
			});

			closeBtn?.addEventListener('click', () => {
				panel?.classList.add('hidden');
			});

			uploadBtn?.addEventListener('click', () => {
				fileInput?.click();
			});

			fileInput?.addEventListener('change', async () => {
				const file = fileInput.files?.[0];
				if (!file) return;
				setStatus(pickerRoot, uploadingMessage);
				try {
					const uploaded = await uploadFile(pickerRoot, file);
					setValue(pickerRoot, uploaded.webp_path, uploaded.thumb_path || '');
					syncPreview(pickerRoot);
					setStatus(pickerRoot, '');
					if (panel && !panel.classList.contains('hidden')) {
						const items = await fetchLibrary();
						renderLibrary(pickerRoot, items);
					}
				} catch (err) {
					setStatus(pickerRoot, err instanceof Error ? err.message : uploadFailedMessage);
				} finally {
					fileInput.value = '';
				}
			});
		});
	}

	(window as any).initImagePathPickers = initImagePathPickers;
	initImagePathPickers(document);
</script>
