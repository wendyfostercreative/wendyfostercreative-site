---
import AdminPageHeader from '../../../../../components/admin/layout/PageHeader.astro';
import AdminPageShell from '../../../../../components/admin/layout/PageShell.astro';
import AdminCard from '../../../../../components/admin/cards/Card.astro';
import AdminSection from '../../../../../components/admin/layout/Section.astro';
import AdminField from '../../../../../components/admin/fields/Field.astro';
import AdminInput from '../../../../../components/admin/fields/Input.astro';
import AdminSelect from '../../../../../components/admin/fields/Select.astro';
import AdminToggleRow from '../../../../../components/admin/fields/ToggleRow.astro';
import AdminActionRow from '../../../../../components/admin/actions/ActionRow.astro';
import AdminToolbar from '../../../../../components/admin/layout/Toolbar.astro';
import Button from '../../../../../components/ui/Button.astro';

import type { MediaCollectionOption } from '../../../core/collections';
import type { AdminMediaImageItem } from '../../../core/types';
import type { SiteProfile } from '../../../../siteProfile/core/types';

type Props = {
	items: AdminMediaImageItem[];
	initialItems: AdminMediaImageItem[];
	searchQuery?: string;
	mediaRole?: string;
	collectionOptions?: MediaCollectionOption[];
	siteProfile?: SiteProfile;
	t: (key: string, fallback: string) => string;
	tf: (key: string, fallback: string, values: Record<string, string | number>) => string;
};

const { items, initialItems, searchQuery = '', mediaRole = 'media_image', collectionOptions = [], siteProfile, t, tf } = Astro.props;

function uniqueOptions(values: string[], currentValue = ''): string[] {
	const seen = new Set<string>();
	return [...values, currentValue]
		.map((value) => String(value || '').trim())
		.filter(Boolean)
		.filter((value) => {
			if (seen.has(value)) return false;
			seen.add(value);
			return true;
		});
}

function labelize(value: string): string {
	return value.replace(/[-_]+/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
}

function displayValue(value: string | number | null | undefined): string {
	const str = String(value ?? '').trim();
	return str || '—';
}

function resolutionLabel(item: AdminMediaImageItem): string {
	const width = Number(item.width || 0);
	const height = Number(item.height || 0);
	return width > 0 && height > 0 ? `${width} x ${height}` : '—';
}

function variantLabel(item: AdminMediaImageItem): string {
	return item.thumb && item.thumb !== item.webp ? 'Main + thumbnail' : 'Main image';
}

const profileMediaRoles = siteProfile?.media_vocabulary.roles ?? [];
const mediaRoleOptions = uniqueOptions(
	profileMediaRoles.length ? profileMediaRoles : ['home_image', 'content_image', 'contact_image', 'media_image'],
	mediaRole,
);
const collectionChoices = collectionOptions.length
	? collectionOptions
	: uniqueOptions(siteProfile?.media_vocabulary.collections ?? []).map((value) => ({ value, label: labelize(value), path: '' }));
const detailDisplayPresets = [
	{ value: 'square', label: 'Square', help: 'Balanced/default detail layout' },
	{ value: 'vertical', label: 'Vertical', help: 'Image emphasized with details to the right' },
	{ value: 'horizontal', label: 'Horizontal', help: 'Wide image with details below' },
];
---

<AdminPageShell width="content">
	<AdminPageHeader
		title={t('admin.media.images.header.title', 'Admin: Image Media')}
		backHref="/admin"
		backLabel={t('admin.media.images.header.back', 'Back')}
		description={t('admin.media.images.header.description', 'Upload images, review thumbnails, and manage the gallery image inventory.')}
	/>

	<AdminCard>
		<form
			id="uploadForm"
			class="grid gap-6"
			method="POST"
			enctype="multipart/form-data"
			action="/admin/action/media/upload"
		>
			<AdminSection title={t('admin.media.images.upload.title', 'Image upload')}>
				<AdminField label={t('admin.media.images.upload.image', 'Image')} forId="file">
					<input
						class="block w-full rounded-[var(--site-radius-input)] border border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] p-2 text-sm text-[var(--admin-color-field-text)] file:mr-3 file:rounded-[var(--site-radius-button)] file:border-0 file:bg-[var(--site-color-button-bg)] file:px-3 file:py-1.5 file:text-sm file:text-[var(--site-color-button-text)]"
						type="file"
						id="file"
						name="file"
						accept="image/jpeg,image/png"
						required
					/>
				</AdminField>
			</AdminSection>

			<AdminSection title={t('admin.media.images.details.title', 'Details')}>
				<div class="grid gap-4 md:grid-cols-2 md:items-start">
					<div class="grid gap-4 md:grid-cols-3">
						<AdminField label={t('admin.media.images.media_role', 'Media role')} forId="media_role">
							<AdminSelect id="media_role" name="media_role">
								{mediaRoleOptions.map((value) => (
									<option value={value} selected={mediaRole === value}>
										{labelize(value)}
									</option>
								))}
							</AdminSelect>
						</AdminField>

						<AdminField label={t('admin.media.images.collection', 'Gallery page')} forId="collection" help={t('admin.media.images.collection_help', 'Choose the Media page where this image should appear.')}>
							<AdminSelect id="collection" name="collection">
								<option value="">{t('admin.media.images.no_collection', 'Choose a gallery page')}</option>
								{collectionChoices.map((option) => (
									<option value={option.value}>{option.label}</option>
								))}
							</AdminSelect>
						</AdminField>

						<AdminField label={t('admin.media.images.category', 'Category')} forId="category">
							<AdminInput id="category" name="category" type="text" />
						</AdminField>
					</div>
					<div class="grid gap-4">
						<AdminField label={t('admin.media.images.title', 'Title')} forId="title">
							<AdminInput id="title" name="title" type="text" />
						</AdminField>
						{mediaRole === 'media_image' ? (
							<AdminField label={t('admin.media.images.detail_display_preset', 'Detail page layout')} forId="detail_display_preset" help={t('admin.media.images.detail_display_preset_help', 'Applies to flexible media library detail pages.')}>
								<AdminSelect id="detail_display_preset" name="detail_display_preset">
									{detailDisplayPresets.map((preset) => (
										<option value={preset.value} selected={preset.value === 'square'}>{preset.label} — {preset.help}</option>
									))}
								</AdminSelect>
							</AdminField>
						) : null}
					</div>
				</div>
				<div class="text-xs text-[var(--site-color-text-muted)]">
					{t('admin.media.images.url_preview', 'URL preview:')} <span id="urlPreview"></span>
				</div>
			</AdminSection>

			<AdminSection>
				<div>
					<AdminField label={t('admin.media.images.description', 'Description')} forId="description">
						<AdminInput id="description" name="description" type="text" class="py-6" />
					</AdminField>
				</div>
			</AdminSection>

			<AdminSection>
				<div class="grid gap-4 md:grid-cols-3">
					<AdminField label={t('admin.media.images.price', 'Price')} forId="price">
						<AdminInput id="price" name="price" type="text" />
					</AdminField>

					<AdminField label={t('admin.media.images.tags', 'Tags (comma-separated)')} forId="tags">
						<AdminInput id="tags" name="tags" type="text" />
					</AdminField>
				</div>
			</AdminSection>

			<AdminSection>
				<div class="grid gap-4 md:grid-cols-3">
					<AdminField label={t('admin.media.images.materials_1', 'Materials 1')} forId="materials1">
						<AdminInput id="materials1" name="materials" type="text" />
					</AdminField>
					<AdminField label={t('admin.media.images.materials_2', 'Materials 2')} forId="materials2">
						<AdminInput id="materials2" name="materials" type="text" />
					</AdminField>
					<AdminField label={t('admin.media.images.materials_3', 'Materials 3')} forId="materials3">
						<AdminInput id="materials3" name="materials" type="text" />
					</AdminField>
				</div>
			</AdminSection>

			<AdminSection title={t('admin.media.images.visibility.title', 'Visibility')}>
				<AdminToggleRow
					id="isPublished"
					name="isPublished"
					label={t('admin.media.images.published', 'Published')}
					help={t('admin.media.images.published_help', 'Uncheck to hide this image from the public gallery.')}
					checked={true}
					hiddenFalse={false}
				/>

				<AdminToggleRow
					id="isFeatured"
					name="isFeatured"
					label={t('admin.media.images.featured', 'Featured')}
					help={t('admin.media.images.featured_help', 'Show this on the home page (max 8).')}
					hiddenFalse={false}
				/>
			</AdminSection>

			<AdminActionRow buttonText={t('admin.media.images.upload_action', 'Upload')} statusId="uploadStatus" />
		</form>
	</AdminCard>

	<section class="grid gap-4">
		<AdminPageHeader title={t('admin.media.images.library.title', 'Library')} compact />

		<AdminToolbar sticky={true}>
			<form method="GET" class="grid gap-3">
				<div class="flex flex-wrap items-center gap-2">
					<AdminSelect id="media_role_filter" name="media_role" density="compact" class="w-auto min-w-44">
						{mediaRoleOptions.map((value) => (
							<option value={value} selected={mediaRole === value}>
								{labelize(value)}
							</option>
						))}
					</AdminSelect>
					<AdminInput
						id="q"
						name="q"
						type="text"
						value={searchQuery}
						class="w-full max-w-md"
						placeholder={t('admin.media.images.search_placeholder', 'Search...')}
					/>
					<Button type="submit">
						{t('admin.media.images.search', 'Search')}
					</Button>
					<Button href="/admin/media/images" variant="outline" tone="neutral">
						{t('admin.media.images.clear', 'Clear')}
					</Button>
				</div>
				<div class="text-xs text-[var(--site-color-text-muted)]">
					{tf('admin.media.images.showing', 'Showing {shown} of {total}', { shown: items.length, total: initialItems.length })}
				</div>
			</form>
		</AdminToolbar>

		<div class="mt-4 flex flex-col gap-3">
			{items.map((item) => (
				<div class="flex items-start overflow-hidden rounded-[var(--site-radius-card)] border border-[var(--site-color-border-soft)] bg-[var(--site-color-panel)] text-[var(--site-color-text)]">
					<div class="pr-3">
						<img class="h-[100px] w-[100px] shrink-0 object-cover" src={item.thumb} alt={item.title ?? item.file} width="100" height="100" loading="lazy" />
					</div>
					<div class="flex min-w-0 flex-1 flex-col gap-2 py-3">
						<div class="truncate text-sm font-medium text-[var(--site-color-text)] md:text-lg" title={item.title ?? item.file}>
							{item.title ?? item.file}
						</div>
						<div class="line-clamp-2 text-xs text-[var(--site-color-text-muted)] md:text-sm" title={item.description ?? ''}>
							{item.description ?? ''}
						</div>
						<div class="grid gap-1 text-xs text-[var(--site-color-text-muted)] sm:grid-cols-2 lg:grid-cols-3">
							<div><span class="font-medium text-[var(--site-color-text)]">Title:</span> {displayValue(item.title)}</div>
							<div><span class="font-medium text-[var(--site-color-text)]">Role:</span> {displayValue(item.media_role ? labelize(item.media_role) : '')}</div>
							<div><span class="font-medium text-[var(--site-color-text)]">Collection:</span> {displayValue(item.collection)}</div>
							<div><span class="font-medium text-[var(--site-color-text)]">Category:</span> {displayValue(item.category)}</div>
							<div><span class="font-medium text-[var(--site-color-text)]">Variant:</span> {variantLabel(item)}</div>
							<div><span class="font-medium text-[var(--site-color-text)]">Resolution:</span> {resolutionLabel(item)}</div>
						</div>
					</div>
					<div class="ml-auto flex flex-col items-end justify-center p-4 text-center">
						<div class="truncate p-1 text-sm font-medium" title={item.price ?? ''}>{item.price ?? ''}</div>
						<Button
							class="text-xs"
							href={`/admin/media/images/edit?file_key=${encodeURIComponent(String(item.file || '').replace(/\.[^.]+$/, ''))}`}
							variant="outline"
							tone="neutral"
						>
							{t('admin.media.images.edit', 'Edit')}
						</Button>
					</div>
				</div>
			))}
		</div>
	</section>
</AdminPageShell>
