---
import AdminField from '../../../../components/admin/fields/Field.astro';

import type { CmsPage } from '../../../pages/core/types';

type Props = {
	pages: CmsPage[];
	starterPageLabels: Record<string, string>;
	t: (key: string, fallback: string) => string;
};

const { pages, starterPageLabels, t } = Astro.props;
const navPages = pages
	.filter((page) => page.published && page.show_in_nav)
	.sort((a, b) => (a.nav_order ?? 999) - (b.nav_order ?? 999) || a.title.localeCompare(b.title));

function starterPageKeyFromPath(path: string): string {
	const normalized = path.trim().toLowerCase();
	if (normalized === '/') return 'home';
	return normalized.replace(/^\/+/, '').replace(/-/g, '_');
}

function starterPageTitle(page: CmsPage): string {
	return starterPageLabels[starterPageKeyFromPath(page.path)] || page.nav_label || page.title;
}

function templateLabel(template: string): string {
	const normalized = template.trim().toLowerCase();
	return t(`admin.pages.templates.${normalized}.label`, normalized.toUpperCase());
}
---

<div class="grid gap-4" data-site-profile-starter-pages-section>
	<AdminField label={t('admin.index.site_profile.starter_pages', 'Starter pages')} help={t('admin.index.site_profile.starter_pages_help', 'Published pages shown in the top navigation at launch. Additional pages can be created later outside this starter plan.')}>
		<div class="grid gap-2" data-site-profile-starter-pages-list>
			{navPages.length ? navPages.map((page) => (
				<div class="grid gap-1 rounded-[var(--site-radius-input)] border border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] px-3 py-2 text-sm text-[var(--admin-color-field-text)] md:grid-cols-[1fr_auto] md:items-center">
					<div>
						<div class="font-medium">{starterPageTitle(page)}</div>
						<div class="text-xs text-[var(--admin-color-field-placeholder)]">{page.path}</div>
					</div>
					<div class="text-xs font-medium uppercase text-[var(--admin-color-field-placeholder)]">{templateLabel(page.template)}</div>
				</div>
			)) : (
				<div class="rounded-[var(--site-radius-input)] border border-[var(--admin-color-field-border)] bg-[var(--admin-color-field-bg)] px-3 py-2 text-sm text-[var(--admin-color-field-placeholder)]">
					{t('admin.index.site_profile.starter_pages_empty', 'No launch navigation pages yet. Orion will suggest and create the first top-nav pages during Site Profile setup.')}
				</div>
			)}
		</div>
	</AdminField>
</div>
