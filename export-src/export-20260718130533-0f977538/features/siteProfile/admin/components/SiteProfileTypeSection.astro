---
import AdminField from '../../../../components/admin/fields/Field.astro';
import AdminSelect from '../../../../components/admin/fields/Select.astro';

import {
	SITE_PROFILE_TYPE_DEFINITIONS,
	siteProfileTypeLabel,
	siteProfileTypeLabelKey,
} from '../../../orion/core/workflow/siteProfile';
import type { SiteProfile } from '../../core/types';

type Props = {
	profile: SiteProfile;
	t: (key: string, fallback: string) => string;
};

const { profile, t } = Astro.props;
const siteProfileTypeKey = typeof profile.metadata?.site_profile_type_key === 'string'
	? profile.metadata.site_profile_type_key
	: typeof profile.metadata?.starter_category_key === 'string'
		? profile.metadata.starter_category_key
	: '';
const currentSiteProfileTypeLabel = siteProfileTypeLabel(siteProfileTypeKey);
---

<div class="grid gap-4" data-site-profile-type-section>
	<AdminField
		label={t('admin.index.site_profile.site_profile_type_setup', 'Site profile type')}
		forId="site_profile_type_key"
		help={t(
			'admin.index.site_profile.site_profile_type_setup_help',
			'This profile type gives Orion an initial set of pages and navigation. You can change, rename, add, or remove pages later in Pages.',
		)}
	>
		<AdminSelect id="site_profile_type_key" name="site_profile_type_key" data-site-profile-type-key-select>
			<option value="">{t('admin.index.site_profile.site_profile_type_setup_empty', 'Choose a site profile type')}</option>
			{SITE_PROFILE_TYPE_DEFINITIONS.map((definition) => (
				<option value={definition.key} selected={definition.key === siteProfileTypeKey}>
					{t(siteProfileTypeLabelKey(definition.key), definition.label)}
				</option>
			))}
		</AdminSelect>
		{currentSiteProfileTypeLabel ? (
			<p class="text-xs text-[var(--admin-color-muted)]">{t(siteProfileTypeLabelKey(siteProfileTypeKey), currentSiteProfileTypeLabel)}</p>
		) : null}
	</AdminField>
</div>
